{
  "name": "integration-reliability-agent",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-incidentclusters": "cds watch --open com.cytechies.integration.reliability.incidentclusters/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy integration-reliability-agent --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-incidentclustersui": "cds watch --open com.cytechies.integration.reliability.incidentclustersui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "type": "module",
  "cds": {
    "requires": {
      "auth": "dummy",
      "db": "sqlite",
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/incidentclusters"
  ]
}
