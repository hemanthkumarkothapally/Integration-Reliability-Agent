<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Popover
        id="artifactPopover"
        title="Associated Artifacts">

        <List items="{path:'monitoredArtifacts'}">
        <CustomListItem
            type="Active"
            press=".onArtifactNav">

            <VBox class="sapUiSmallMargin">

                <HBox justifyContent="SpaceBetween">
                    <Text  text="{artifact/iFlowName}" />
                    <Title text="{path:'artifact/lastErrorAt', formatter:'.formatter.formatDateTime'}" />
                </HBox>
<HBox justifyContent="SpaceBetween">
                <Text text="{artifact/PackageName}" />
                 <ObjectStatus text="{path:'artifact/overallSeverity', formatter:'.formatter.formatButtonText'}" icon="{path:'artifact/overallSeverity', formatter:'.formatter.formatSeverityIcon'}" state="{path:'artifact/overallSeverity', formatter:'.formatter.formatSeverityState'}">
                                        <customData>
                                            <core:CustomData key="severity" value="{artifact/overallSeverity}" />
                                        </customData>
                                    </ObjectStatus>
                                    </HBox>

                <!-- <ObjectStatus state="" text="{artifact/overallSeverity}"/> -->

            </VBox>

        </CustomListItem>


            

        </List>

    </Popover>

</core:FragmentDefinition>