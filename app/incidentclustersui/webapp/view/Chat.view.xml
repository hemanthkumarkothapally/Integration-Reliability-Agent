<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Chat"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core" displayBlock="true">

    <mvc:dependents>
        <ResponsivePopover id="activeClusterPopover" placement="Top" title="{i18n>activeClusterPopover.title}" class="sapUiContentPadding">

            <VBox alignItems="Center">
                <MessageStrip text="{chatJSONModel>/clusterName}" type="Warning" showIcon="true" customIcon="sap-icon://share-2" class="sapUiSmallMarginBottom" />
                <!-- <Button type="Attention" text="{chatJSONModel>/clusterName}" icon="sap-icon://share-2" /> -->
                <Button text="{i18n>remove.popover.cluster.button}" type="Reject" icon="sap-icon://delete" press=".onRemoveClusterPress" />
            </VBox>

        </ResponsivePopover>
        <ResponsivePopover id="activeiFlowPopover" placement="Top" title="{i18n>activeiFlowPopover.title}" class="sapUiContentPadding">

            <VBox alignItems="Center">
                <MessageStrip text="{chatJSONModel>/iFlowName}" type="Information" showIcon="true" customIcon="sap-icon://process" class="sapUiSmallMarginBottom" />
                <!-- <Button type="Attention" text="{chatJSONModel>/clusterName}" icon="sap-icon://share-2" /> -->
                <Button text="{i18n>remove.popover.iflow.button}" type="Reject" icon="sap-icon://delete" press=".onRemoveiFlowPress" />
            </VBox>

        </ResponsivePopover>

        <ResponsivePopover id="actionDataPopover" placement="Top" showHeader="false" contentWidth="auto">
            <content>
                <VBox class="sapUiTinyMargin">
                    <!-- <Button text="Attach Cluster" type="Ghost" icon="sap-icon://add-process" tooltip="{i18n>cluster.toggle.attach.tooltip}" visible="{= !${chatJSONModel>/clusterDataEnabled} }" press=".onToggleClusterData" width="100%" /> -->
                    <Button text="{i18n>actionDataPopover.cluster.button}" type="Attention" icon="sap-icon://share-2" tooltip="{i18n>cluster.toggle.attach.tooltip}" visible="{= !${chatJSONModel>/clusterDataEnabled} &amp;&amp; !${chatJSONModel>/iFlowDataEnabled} }" press=".onSelectClusterData" width="100%" />

                    <Button text="{i18n>actionDataPopover.iflow.button}" type="Neutral" icon="sap-icon://add-process" tooltip="{i18n>cluster.toggle.attach.tooltip}" visible="{= !${chatJSONModel>/clusterDataEnabled} &amp;&amp; !${chatJSONModel>/iFlowDataEnabled} }" press=".onSelectiFlowData" width="100%" />

                    <!-- <Button text="Upload File" type="Ghost" icon="sap-icon://attachment" tooltip="Insert Image or Document" press=".onUploadFilePress" width="100%" /> -->

                    <!-- <Button text="Voice Input" type="Ghost" icon="sap-icon://microphone" tooltip="Record Audio" press=".onVoiceInputPress" width="100%" /> -->

                </VBox>
            </content>
        </ResponsivePopover>

        <ResponsivePopover id="historyPopover" title="{i18n>history.popover.title}" placement="Bottom" contentWidth="auto">
            <content>
                <List id="historyList" items="{chatModel>/ChatSessions}" mode="SingleSelectMaster" selectionChange=".onConversationSelect">
                    <headerToolbar>
                        <Toolbar>
                            <SearchField id="historySearchField" width="100%" placeholder="{i18n>history.search.placeholder}" liveChange=".onHistorySearch" search=".onHistorySearch" />
                        </Toolbar>
                    </headerToolbar>
                    <items>
                        <StandardListItem id="_IDGenStandardListItem" title="{chatModel>title}" description ="{chatModel>modifiedAt}" info="{chatModel>totalSessionTokenUsage}" icon="sap-icon://discussion" />
                    </items>
                </List>
            </content>
        </ResponsivePopover>

        <ResponsivePopover id="iFlowPopover" placement="Right" title="{i18n>iFlowPopover.title}">
            <content>
                <List id="iFlowList" mode="SingleSelectMaster" width="300px" selectionChange=".oniFlowSelect" items="{
                path: '/MonitoredArtifacts', 
                sorter: {
                    path: 'lastPollTimestamp',
                    descending: true
                }
            }">
                    <headerToolbar>
                        <Toolbar>
                            <SearchField id="iFlowSearchField" width="100%" placeholder="Search iFlows..." liveChange=".oniFlowSearch" search=".oniFlowSearch" />
                        </Toolbar>
                    </headerToolbar>
                    <items>
                        <CustomListItem type="Active">
                            <VBox class="sapUiSmallMargin" width="100%">

                                <HBox justifyContent="SpaceBetween" alignItems="Center" width="90%">
                                    <items>
                                        <Title text="{iFlowName}" wrapping="true" width="100%" class="sapMTitleStyleH6 sapUiTinyMarginEnd" tooltip="{iFlowName}">
                                            <layoutData>
                                                <FlexItemData growFactor="1" minWidth="0" />
                                            </layoutData>
                                        </Title>
                                    </items>
                                </HBox>
                                <ObjectNumber number="{openClusterCount}" unit="Clusters" emphasized="true" state="{path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}">

                                </ObjectNumber>
                                <ObjectStatus text="{overallSeverity}" state="{path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}" />
                                <Text text="{path: 'lastPollTimestamp', formatter: '.formatter.formatDateTime'}" class="sapUiTinyMarginTop" />
                            </VBox>
                        </CustomListItem>
                    </items>
                </List>
            </content>
        </ResponsivePopover>

        <ResponsivePopover id="clusterPopover" placement="Right" title="{i18n>clusterPopover.title}">
            <content>
                <List id="clusterList" mode="SingleSelectMaster" selectionChange=".onClusterSelect" items="{
              path: '/IncidentClusters',
              sorter: {
                  path: 'modifiedAt',
                  descending: true
              }
          }">
                    <headerToolbar>
                        <Toolbar>
                            <SearchField id="clusterSearchField" placeholder="Search clusters..." liveChange=".onClusterSearch" search=".onClusterSearch" />
                        </Toolbar>
                    </headerToolbar>
                    <items>
                        <CustomListItem type="Active">
                            <VBox class="sapUiSmallMargin">
                                <HBox justifyContent="SpaceBetween" alignItems="Center">
                                    <Title text="{errorType}" wrapping="true" class="sapMTitleStyleH6" />
                                    <ObjectNumber number="{incidentCount}" emphasized="true" />
                                </HBox>
                                <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginTop">
                                    <ObjectStatus text="{severity}" state="{
                            path: 'severity',
                            formatter: '.formatter.formatSeverityState'
                        }" />
                                    <ObjectStatus text="{status}" state="{
                            path: 'status',
                            formatter: '.formatter.formatStatusState'
                        }" />
                                </HBox>
                                <Text text="{
                        path: 'lastSeen',
                        formatter: '.formatter.formatDateTime'
                    }" class="sapUiTinyMarginTop" />
                            </VBox>
                        </CustomListItem>
                    </items>
                </List>
            </content>
        </ResponsivePopover>
    </mvc:dependents>
    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <tnt:ToolHeader id="_IDGenToolHeader">
                <Button id="backbutton" icon="sap-icon://nav-back" press=".onBackPress" tooltip="{i18n>backButton.tooltip}" type="Ghost">
                    <layoutData>
                        <OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData3" priority="NeverOverflow" />
                    </layoutData>
                </Button>
                <Title id="_IDGenTitle3" text="{i18n>toolHeader.title}" wrapping="true"/>
                <ToolbarSpacer id="_IDGenToolbarSpacer2" />
                <Button id="_IDGenButton1" icon="sap-icon://add" press=".onNewChat" tooltip="{i18n>newChat.tooltip}"  type="Ghost">
                    <layoutData>
                        <OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData1" priority="NeverOverflow" />
                    </layoutData>
                </Button>

                <Button id="historyMenuBtn" icon="sap-icon://history" type="Ghost" press=".onHistoryMenuPress" tooltip="{i18n>chatHistory.tooltip}">
                    <layoutData>
                        <OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData2" priority="NeverOverflow" />
                    </layoutData>
                </Button>
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:mainContents>
            <NavContainer id="navContainer">
                <pages>
                    <Page id="chatPage" showHeader="true" backgroundDesign="Transparent" floatingFooter="true" enableScrolling="false">
                        <customHeader>
                            <Toolbar id="_IDGenToolbar">

                                <Title id="_IDGenTitle1" text="{= ${chatJSONModel>/currentConversationTitle} || 'New Chat' }" class="sapUiSmallMarginBegin" wrapping="false" />
                                <ToolbarSpacer id="_IDGenToolbarSpacer1" />
                                <ObjectStatus id="_IDGenObjectStatus10" text="{= (${chatJSONModel>/currentConversationTokens} || 'No') + ' Tokens' }" state="Success" class="sapUiSmallMarginEnd" visible="{= ${chatJSONModel>/currentConversationId} !== null }" />
                                <Button id="_IDGenButton" icon="sap-icon://delete" type="Reject" press=".onDeleteConversation" tooltip="{i18n>chat.header.deleteTooltip}" />
                            </Toolbar>
                        </customHeader>

                        <content>
                            <ScrollContainer id="chatScroll" vertical="true" horizontal="false" width="100%" height="100%">
                                <VBox id="welcomePage" width="90%" justifyContent="Center" alignItems="Center" class="sapUiMediumMargin">
                                    <Avatar id="_IDGenAvatar" src="sap-icon://ai" displaySize="XL" backgroundColor="Accent6" class="sapUiMediumMarginBottom"/>
                                    <Title id="_IDGenTitle2" text="{i18n>welcome.title}" level="H1" titleStyle="H2" wrapping="true" textAlign="Center" width="100%"/>
                                    <Text id="_IDGenText13" text="{i18n>welcome.subtitle}" class="sapUiSmallMarginTop" textAlign="Center" width="100%"/>
                                    <VBox id="faqContainer" class="sapUiMediumMarginTop" width="100%" alignItems="Center">
                                        <Label id="_IDGenLabel1" text="{i18n>welcome.suggestions.label}" design="Bold" class="sapUiTinyMarginBottom"/>
                                        <FlexBox id="_IDGenFlexBox" wrap="Wrap" justifyContent="Center" width="85%" renderType="Bare">
                                            <Button id="_IDGenButton2" text="{i18n>welcome.suggestion.s1}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                            <Button id="_IDGenButton4" text="{i18n>welcome.suggestion.s2}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                            <Button id="_IDGenButton5" text="{i18n>welcome.suggestion.s3}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                            <Button id="_IDGenButton6" text="{i18n>welcome.suggestion.s4}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                            <Button id="_IDGenButton7" text="{i18n>welcome.suggestion.s5}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                            <Button id="_IDGenButton8" text="{i18n>welcome.suggestion.s6}" type="Ghost" class="sapUiTinyMargin" press=".onSuggestionPress"/>
                                        </FlexBox>

                                    </VBox>
                                </VBox>
                                <VBox id="chatContainer" width="100%" class="sapUiResponsiveContentPadding" />
                                <HBox id="typingIndicator" visible="false" class="sapUiSmallMargin">
                                    <BusyIndicator id="_IDGenBusyIndicator" size="1.6rem" class="sapUiMediumMarginBegin" />
                                </HBox>
                            </ScrollContainer>
                        </content>

                        <footer>

                            <OverflowToolbar id="chatFooter" style="Clear" height="auto">

                                <Button id="addActionsBtn" icon="sap-icon://add" visible="{= !${chatJSONModel>/clusterDataEnabled} &amp;&amp; !${chatJSONModel>/iFlowDataEnabled} }" type="Transparent" press=".onOpenActionsPopover" tooltip="More options">
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                                    </layoutData>
                                </Button>
                                <Button type="Attention" icon="sap-icon://share-2" tooltip="{i18n>cluster.toggle.detach.tooltip}" visible="{chatJSONModel>/clusterDataEnabled}" press=".onClusterInfoPopover">
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                                    </layoutData>
                                </Button>
                                <Button type="Neutral" icon="sap-icon://process" tooltip="{i18n>cluster.toggle.detach.tooltip}" visible="{chatJSONModel>/iFlowDataEnabled}" press=".oniflowInfoPopover">
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                                    </layoutData>
                                </Button>

                                <BusyIndicator id="_IDGenBusyIndicator1" visible="false" />


                                <TextArea id="chatInput1" class="noBorderTextArea" growing="true" growingMaxLines="3" rows="1" width="100%" wrapping="Soft" placeholder="{= ${chatJSONModel>/clusterDataEnabled} ? ${i18n>input.placeholder.clusterActive} : ${i18n>input.placeholder.default} }">
                                    <layoutData>
                                        <OverflowToolbarLayoutData shrinkable="true" minWidth="100px" priority="Low" />
                                    </layoutData>
                                </TextArea>

                                <Button id="_IDGenButton3" icon="sap-icon://paper-plane" type="Neutral" press=".onPost" class="sapUiTinyMarginBegin" tooltip="{i18n>send.button.tooltip}">
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                                    </layoutData>
                                </Button>

                                <Button id="scrollBottomBtn" icon="sap-icon://arrow-bottom" type="Emphasized" press="._scrollToBottom" tooltip="Scroll to latest" class="sapUiTinyMarginEnd" visible="{chatJSONModel>/showScrollButton}">
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                                    </layoutData>
                                </Button>

                            </OverflowToolbar>
                        </footer>
                    </Page>
                </pages>
            </NavContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
 
 
