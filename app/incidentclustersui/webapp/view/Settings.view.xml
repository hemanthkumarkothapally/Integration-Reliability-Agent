<mvc:View xmlns:cssgrid="sap.ui.layout.cssgrid" xmlns:form="sap.ui.layout.form"
    controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Settings"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:cards="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <f:DynamicPage showFooter="true">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Settings" wrapping="true"/>
                </f:heading>
                <f:expandedHeading>
                    <Text text="Manage tenant configuration and data retention policies"/>
                </f:expandedHeading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
        
<layout:Grid
    defaultSpan="L6 M6 S12"
    hSpacing="1"
    vSpacing="1">                            <!-- ============================================ -->
                            <!-- 1. TENANT CONFIGURATION                      -->
                            <!-- ============================================ -->
                            
                            <f:Card height="100%" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://building"
                                        title="1. Tenant Configuration"
                                        subtitle="Default Dashboard Tenant"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                        <Label text="Default Dashboard Tenant"/>
                                        <Select
                                            width="100%"
                                            selectedKey="{settingsModel>/DEFAULT_TENANT/settingValue}"
                                            items="{globalModel>/tenants}"
                                            enabled="{= !${globalModel>/editMode}}"
                                            change=".onTenantChange">
                                            <core:Item
                                                key="{globalModel>ID}"
                                                text="{globalModel>tenantName}"/>
                                        </Select>
                                        <MessageStrip
                                            class="sapUiMediumMarginTop"
                                            type="Information"
                                            showIcon="true"
                                            text="This tenant will be selected automatically when users open the dashboard."/>
                                            <VBox
                                        visible="{globalModel>/editMode}"
                                        class="sapUiMediumMarginTop">

                                        <Toolbar>
                                            <Title text="Tenant Management" level="H5"/>
                                            <ToolbarSpacer/>
                                            <Button
                                                text="Add Tenant"
                                                icon="sap-icon://add"
                                                type="Emphasized"
                                                press=".onAddTenant"/>
                                        </Toolbar>

                                        <Table
                                        id="tenantTable"
                                            items="{path: '/Tenants'}"
                                            class="sapUiSmallMarginTop" autoPopinMode="true">
                                            <columns>
                                                <Column demandPopin="true">
                                                    <Text text="Tenant Name"/>
                                                </Column>
                                                <Column>
                                                    <Text text="Tenant ID"/>
                                                </Column>
                                                <Column>
                                                    <Text text="Destination"/>
                                                </Column>
                                                <Column>
                                                    <Text text="URL"/>
                                                </Column>
                                                <Column visible="false" >
                                                <Text text="IsActive"></Text>
                                                </Column>
                                                <Column hAlign="Center">
                                                    <Text text="Actions"/>
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem>
                                                    <cells>
                                                        <Text text="{tenantName}"/>
                                                        <Text text="{tenantId}"/>
                                                        <Text text="{destinationName}"/>
                                                        <Text text="{url}"/>
                                                        <Text text="{isActive}" visible="false"></Text>
                                                        <HBox justifyContent="Center">
                                                            <Button
                                                                icon="sap-icon://edit"
                                                                type="Transparent"
                                                                press=".onEditTenant"/>
                                                            <Button
                                                                icon="sap-icon://delete"
                                                                type="Transparent"
                                                                press=".onDeleteTenant"/>
                                                        </HBox>
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </VBox>
                                                </VBox>
                                </f:content>
                            </f:Card>


                            <!-- ============================================ -->
                            <!-- 2. AI CONFIGURATION                          -->
                            <!-- ============================================ -->
                            <f:Card height="100%" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://artificial-intelligence"
                                        title="2. AI Configuration"
                                        subtitle="Recommendation Engine Settings"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                    <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                                <Label text="AI Provider"/>
                                                <Text id="aiProvider" text="{AdminModel>settingValue}" />
                                                <Label text="Model"/>
                                                <Text id="aiModel" text="{AdminModel>settingValue}"></Text>
                                                <Label text="Max Incidents Sent to AI"/>
                                                <StepInput
                                                    id="maxIncidents"
                                                    width="100%"
                                                    description="Count"
                                                    textAlign="Center"
                                                    min="1"
                                                    max="100"
                                                    value="{AdminModel>settingValue}"
                                                    enabled="{globalModel>/editMode}"/>
                                                <Label text="Historical Messages Count"/>
                                                <StepInput
                                                id="historyCount"
                                                    width="100%"
                                                    description="Count"
                                                    textAlign="Center"
                                                    min="0"
                                                    max="100"
                                                    value="{AdminModel>settingValue}"
                                                    enabled="{globalModel>/editMode}"/>
                                    </form:content>
                                    </form:SimpleForm>
                                    </VBox>
                                </f:content>
                            </f:Card>


                            <!-- ============================================ -->
                            <!-- 3. POLLING CONFIGURATION                     -->
                            <!-- ============================================ -->
                            <f:Card  class="sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://refresh"
                                        title="3. Polling Configuration"
                                        subtitle="Monitoring Schedule"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                         <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                    <Label text="Polling Mode"></Label>
                                     <RadioButtonGroup
                                     id="pollingMode"
                                                columns="2"
                                                enabled="{globalModel>/editMode}"
                                                selectedIndex="{AdminModel>settingValue}"
                                                select=".onPollingModeChange">
                                                <RadioButton  text="Automatic"/>
                                                <RadioButton text="Manual"/>
                                            </RadioButtonGroup>
                                             <Label text="Polling Frequency"/>
                                             <StepInput
                                                id="pollingInterval"
                                                    width="100%"
                                                    description="Mins"
                                                    textAlign="Center"
                                                    min="5"
                                                    max="180"
                                                    step="5"
                                                    value="{AdminModel>settingValue}"
                                                    enabled="{globalModel>/editMode}"/>
                                    </form:content>
                                    </form:SimpleForm>

                                        <!-- Poll Now -->


    <Button
        text="Poll Now"
        icon="sap-icon://play"
        press=".onPollNow"/>

    
                                    </VBox>
                                </f:content>
                            </f:Card>
                            <f:Card class="sapUiMediumMarginBottom">
    <f:header>
        <cards:Header
            iconSrc="sap-icon://activity-items"
            title="Tenant Poll Status"
            subtitle="Latest polling status for each tenant"/>
    </f:header>

    <f:content>

    <List items="{globalModel>/tenantPollStatus}">
    <ObjectListItem
        title="{globalModel>tenantName}"
        number="{globalModel>lastPollStatus} "
        numberState="{=
            ${globalModel>lastPollStatus} === 'SUCCESS'
            ? 'Success'
            : 'Error'
        }">

        <firstStatus>
            <ObjectStatus
                text="{
                    path:'globalModel>lastPollAt',
                    formatter:'.formatter.formatDateTime'
                }"/>
        </firstStatus>

    </ObjectListItem>
</List>

    </f:content>
</f:Card>
                            <f:Card height="100%" width="100%" class="sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://database"
                                        title="4. Data Retention"
                                        subtitle="Automatic Cleanup Configuration"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                            <Label text="Incident Retention Days"/>
                                            <StepInput
                                            id="incidentRetention"
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{AdminModel>settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                            <Label text="Cluster Retention Days"/>
                                            <StepInput
                                            id="clusterRetention"
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{AdminModel>settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                            <Label text="Monitoring Iflows Retention Days"/>
                                            <StepInput
                                            id="iflowRetention"
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{AdminModel>settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                                </form:content>
                                    </form:SimpleForm>

                                        <MessageStrip
                                            class="sapUiMediumMarginTop"
                                            type="Warning"
                                            showIcon="true"
                                            text="Records older than the configured retention period will be automatically deleted by scheduled cleanup jobs."/>
                                    </VBox>
                                  
                                </f:content>
                            </f:Card>

                            </layout:Grid>
                      
                    

        </f:content>

        <!-- ====================================================== -->
        <!-- FOOTER: Edit / Cancel / Save + Reset                   -->
        <!-- ====================================================== -->
        <f:footer>
            <Toolbar>
                <Button
                    text="Reset to Defaults"
                    icon="sap-icon://reset"
                    type="Transparent"
                    visible="{globalModel>/editMode}"
                    press=".onResetDefaults"/>

                <ToolbarSpacer/>

                <Button
                    text="Edit"
                    icon="sap-icon://edit"
                    type="Emphasized"
                    visible="{= !${globalModel>/editMode} }"
                    press=".onEdit"/>

                <Button
                    text="Cancel"
                    icon="sap-icon://decline"
                    visible="{globalModel>/editMode}"
                    press=".onCancel"/>

                <Button
                    text="Save Settings"
                    icon="sap-icon://save"
                    type="Accept"
                    visible="{globalModel>/editMode}"
                    press=".onSave"/>
            </Toolbar>
        </f:footer>

    </f:DynamicPage>

</mvc:View>