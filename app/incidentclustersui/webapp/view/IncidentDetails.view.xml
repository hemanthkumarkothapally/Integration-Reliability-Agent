<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.IncidentDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:suite="sap.suite.ui.commons"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:m="sap.m" height="100%">

    <ObjectPageLayout  headerContentPinned="true" height="100vh" id="ObjectPageLayout" showTitleInHeaderContent="true" showFooter="true" upperCaseAnchorBar="false">

        <headerTitle>
            <ObjectPageDynamicHeaderTitle  id="_IDGenObjectPageDynamicHeaderTitle">


                <!-- EXPANDED -->
                <expandedContent>
                    <!-- <m:FlexBox alignItems="Center">
                        <m:Title id="_IDGenTitle4" text="{headerDetails>/errorType}" level="H1" titleStyle="H1" wrapping="true" />
                    </m:FlexBox> -->
                    <m:Title id="_IDGenTitle4" text="{iFlowName}" level="H2" titleStyle="H2" wrapping="true" />
                </expandedContent>
                <expandedHeading>

                    <m:Button icon="sap-icon://nav-back" type="Ghost" press=".onNavBack" class="sapUiTinyMarginEnd" tooltip="{i18n>backButton.tooltip}" />


                </expandedHeading>

                <actions>
                    <m:Button id="_IDGenButton10" icon="sap-icon://ai" text="Ai Assistant" type="Ghost" press=".onAipress" tooltip="AI Assistant">
                        <m:layoutData>
                            <m:OverflowToolbarLayoutData priority="NeverOverflow" />
                        </m:layoutData>
                    </m:Button>
                </actions>

                <!-- SNAPPED -->
                <snappedHeading>

                    <m:FlexBox id="_IDGenFlexBox1" fitContainer="true" alignItems="Center">

                        <m:Button id="_IDGenButton11" icon="sap-icon://nav-back" type="Ghost" press=".onNavBack" class="sapUiTinyMarginEnd" />

                        <!-- <m:Title text="{headerDetails>/errorType}" level="H2" titleStyle="H2" wrapping="true" /> -->



                    </m:FlexBox>

                </snappedHeading>
                <snappedContent>

                    <m:FlexBox fitContainer="true" alignItems="Center">


                        <m:Title text="{iFlowName}" level="H2" titleStyle="H2" wrapping="true" />



                    </m:FlexBox>

                </snappedContent>

                <snappedTitleOnMobile>
                    <m:Title text="{iFlowName}" level="H3" titleStyle="H3" wrapping="true" />

                </snappedTitleOnMobile>


            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

        <headerContent>

            <m:FlexBox id="_IDGenFlexBox2" wrap="Wrap" justifyContent="SpaceBetween" alignItems="Start" width="100%">
                <m:FlexBox id="_IDGenInnerFlexBox" wrap="Wrap">
                    <layout:VerticalLayout id="_IDGenVerticalLayout" class="sapUiSmallMarginBeginEnd">

                        <!-- <m:ObjectStatus title="iFlow Name" text="{headerDetails>/errorType}" /> -->

                        <m:ObjectStatus id="_IDGenObjectStatus2" title="Severity" text="{overallSeverity}" state="{= ${overallSeverity} === 'CRITICAL' ? 'Error' : ${overallSeverity} === 'HIGH' ? 'Warning' : ${overallSeverity} === 'MEDIUM' ? 'Information' : ${overallSeverity} === 'LOW' ? 'Success' : 'None' }" />
                        <!-- <m:ObjectStatus title="Status" text="{headerDetails>/status}" /> -->

                        <!-- <m:ObjectStatus title="Error Type" text="{headerDetails>/errorSignature}" /> -->
                        <m:ObjectStatus id="_IDGenObjectStatus3" title="Incident Count" text="{/MonitoredArtifacts/$count}" />

                        <m:ObjectStatus id="_IDGenObjectStatus" title="Confidence Score" />
                        <m:ProgressIndicator displayOnly="false" id="_IDGenProgressIndicator" percentValue="{details>/confidenceScore}" displayValue="{details>/confidenceScore}%" showValue="true" class="sapUiNoMarginTop" state="{= ${details>/confidenceScore} === null || !${details>/confidenceScore} ? 'None' : (${details>/confidenceScore} &lt;= 33 ? 'Error' : (${details>/confidenceScore} &lt;= 66 ? 'Warning' : 'Success')) }" />


                    </layout:VerticalLayout>

                    <layout:VerticalLayout id="_IDGenVerticalLayout1" class="sapUiSmallMarginBeginEnd">
                        <m:ObjectStatus id="_IDGenObjectStatus1" title="Status" text="{= ${isActive} === 'Yes' ? 'ACTIVE' : 'INACTIVE' }" state="{= ${isActive} === 'Yes' ? 'Success' : 'Error' }" />

                        <m:ObjectStatus id="_IDGenObjectStatus4" title="First Seen" text="{
                            path: 'headerDetails>/firstSeen',
                            formatter: '.formatter.formatDateTime'
                        }" />

                        <m:ObjectStatus id="_IDGenObjectStatus5" title="Last Seen" text="{
                            path: 'headerDetails>/lastSeen',
                            formatter: '.formatter.formatDateTime'
                        }"/>
                    </layout:VerticalLayout>

                    <!-- <layout:VerticalLayout id="_IDGenVerticalLayout2" class="sapUiSmallMarginBeginEnd">

                        <m:ObjectStatus id="_IDGenObjectStatus6" title="Created By" text="{headerDetails>/createdBy}" />

                        <m:ObjectStatus id="_IDGenObjectStatus7" title="Modified By" text="{headerDetails>/modifiedBy}" />

                    </layout:VerticalLayout> -->
                </m:FlexBox>
                <layout:VerticalLayout id="_IDGenVerticalLayout3" class="sapUiSmallMarginBeginEnd">
                    <m:ObjectNumber id="_IDGenObjectNumber" number="{= ${headerDetails>/totalTokenUsage} ? ${headerDetails>/totalTokenUsage} : 0 }" unit="Tokens used" emphasized="true" state="Information" class="sapMObjectNumberLarge"/>
                </layout:VerticalLayout>


            </m:FlexBox>

        </headerContent>

        <sections>

            <!-- ROOT CAUSE -->
           <ObjectPageSection  id="_IDGenSectionClusters" title="Clusters" showTitle="false">
    <subSections>
        <ObjectPageSubSection id="_IDGenSubSectionClusters" class="sapUiNoBackgroundColor">
            <blocks>
<m:ScrollContainer  id="_IDGenScrollContainer1" height="100%" width="100%" vertical="true" horizontal="false" class="sapUiContentPadding">
                <m:VBox id="_IDGenVBoxClusters" items="{view>/clusters}" class="sapUiContentPadding">
<!-- 
                    <f:Card class="sapUiSmallMarginBottom">
                        <f:content> -->
                            <m:Panel expandable="true" expanded="false" width="100%" expandAnimation="false" class="sapUiNoBackgroundColor sapUiCard sapUiMediumMarginBottom sapUiSmallMarginBottom">

                                <!-- <m:headerToolbar>
                                    <m:Toolbar height="3rem" design="Transparent">
                                        <m:ObjectStatus
                                            text="{view>cluster/severity}"
                                            state="{= ${view>cluster/severity} === 'CRITICAL' ? 'Error' : ${view>cluster/severity} === 'HIGH' ? 'Warning' : ${view>cluster/severity} === 'MEDIUM' ? 'Information' : 'Success' }"
                                            inverted="true"
                                            class="sapUiTinyMarginEnd" />
                                        <m:Title text="{view>cluster/errorType}" level="H5" />
                                        <m:ToolbarSpacer />
                                        <m:Text text="{view>cluster/incidentCount} Incidents" class="sapUiTinyMarginEnd" />
                                       <m:Button id="_IDGenButton13" type="Success" text="Resolve" icon="sap-icon://complete" press="onResolve" enabled="{= ${headerDetails>/status} === 'OPEN' }" />
                                    </m:Toolbar>
                                </m:headerToolbar> -->
<m:headerToolbar>
        <m:Toolbar height="4.5rem" class="sapUiContentPadding">
            <!-- Main Horizontal Flex Wrapper for exact column distribution -->
            <m:FlexBox width="100%" alignItems="Center" justifyContent="SpaceBetween">
                
                <!-- COLUMN 1: Title & Subtext (Left Aligned) -->
                <m:HBox width="15%" alignItems="Center">
                    <m:Text text="{view>cluster/errorType}"  class="sapUiTinyMarginBottom" />                
</m:HBox>
                <!-- COLUMN 2: Severity Status Badge -->
                <m:HBox width="15%" alignItems="Center">
                    <!-- <m:ObjectStatus
                        text="{view>cluster/severity}"
                        state="{= ${view>cluster/severity} === 'CRITICAL' ? 'Error' : ${view>cluster/severity} === 'HIGH' ? 'Warning' : ${view>cluster/severity} === 'MEDIUM' ? 'Information' : 'Success' }"
                        icon="sap-icon://overlay"
                         /> -->
                         <m:GenericTag design="StatusIconHidden" text="{view>cluster/severity}" status="{= ${view>cluster/severity} === 'CRITICAL' ? 'Error' : ${view>cluster/severity} === 'HIGH' ? 'Warning' : ${view>cluster/severity} === 'MEDIUM' ? 'Information' : 'Success' }"></m:GenericTag>
                </m:HBox>

                <!-- COLUMN 3: Incident Counter -->
                <m:HBox width="10%" alignItems="Center">
                    <m:Title text="{view>cluster/incidentCount}" level="H4" titleStyle="H4" />
                </m:HBox>

                <!-- COLUMN 4: Timestamp Date -->
                <m:HBox width="15%" alignItems="Center">
                    <m:Text text="2025-05-20" class="sapUiTextMuted" />
                </m:HBox>

                <!-- COLUMN 5: Processing State Badge -->
                <m:HBox width="15%" alignItems="Center">
                    <m:ObjectStatus
                        text="{view>resolutionStatus}"
                        state="{= ${{view>resolutionStatus} === 'OPEN' ? 'Information' : 'Success' }"
                        inverted="true" />
                </m:HBox>

                <!-- COLUMN 6: Action Trigger Button (Right Aligned) -->
                <m:HBox width="15%" justifyContent="End" alignItems="Center">
                    <m:Button 
                        text="Resolve" 
                        icon="sap-icon://complete"
                        type="Emphasized" 
                        press="onResolve" 
                        enabled="{= ${headerDetails>/status} === 'OPEN' }" />
                </m:HBox>

            </m:FlexBox>
        </m:Toolbar>
    </m:headerToolbar>


                                <m:VBox class="sapUiSmallMargin">

                                    <!-- Root Cause Analysis -->
                                    <m:VBox class="sapUiSmallMarginBottom vboxborderclass">
                                        <m:HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <m:Avatar src="sap-icon://inspection" displaySize="XS" class="sapUiTinyMarginEnd" />
                                            <m:Title text="Root Cause Analysis" level="H6" />
                                        </m:HBox>
                                        <m:Text text="{view>cluster/recommendations/rootCause}" wrapping="true" />
                                    </m:VBox>

                                    <!-- Business Impact -->
                                    <m:VBox class="sapUiSmallMarginBottom vboxborderclass">
                                        <m:HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <m:Avatar src="sap-icon://business-objects-experience" displaySize="XS" class="sapUiTinyMarginEnd" />
                                            <m:Title text="Business Impact" level="H6" />
                                        </m:HBox>
                                        <m:Text text="{view>cluster/recommendations/businessImpact}" wrapping="true" />
                                    </m:VBox>

                                    <!-- Remediation Steps as Timeline -->
                                    <m:VBox class="sapUiSmallMarginBottom vboxborderclass">
                                        <m:HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <m:Avatar src="sap-icon://activity-items" displaySize="XS" class="sapUiTinyMarginEnd" />
                                            <m:Title text="Remediation Steps" level="H6" />
                                        </m:HBox>

                                        <suite:Timeline
                                            showIcons="false"
                                            showHeaderBar="false"
                                            enableScroll="false"
                                            content="{view>cluster/recommendations/parsedSteps}">

                                            <suite:TimelineItem
                                                userName="{view>title}"
                                                text="{view>text}"
                                                userNameClickable="false" />

                                        </suite:Timeline>
                                    </m:VBox>

                                </m:VBox>

                            </m:Panel>
                        <!-- </f:content>
                    </f:Card> -->

                </m:VBox>
</m:ScrollContainer>
            </blocks>
        </ObjectPageSubSection>
    </subSections>
</ObjectPageSection>


            <!-- BUSINESS IMPACT -->


        </sections>


        <!-- <footer>

            <m:OverflowToolbar id="_IDGenOverflowToolbar1">

                <m:ToolbarSpacer id="_IDGenToolbarSpacer3" />

                <m:Button id="_IDGenButton12" visible="false" text="Re-diagnose" type="Attention" icon="sap-icon://ai" press="Rediagnose" />

                <m:Button id="_IDGenButton13" text="Resolve" type="Accept" icon="sap-icon://complete" press="onResolve" enabled="{= ${headerDetails>/status} === 'OPEN' }" />

            </m:OverflowToolbar>

        </footer> -->
    </ObjectPageLayout>
</mvc:View>
 
 