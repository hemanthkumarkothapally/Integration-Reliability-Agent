<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.IncidentDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:suite="sap.suite.ui.commons"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:m="sap.m" height="100%">

    <ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="true" upperCaseAnchorBar="false">
        <headerTitle>
            <ObjectPageDynamicHeaderTitle id="_IDGenObjectPageDynamicHeaderTitle">

                <!-- EXPANDED -->
                <expandedHeading>

                    <m:Title id="_IDGenTitle4" text="{headerDetails>/iFlowName}" wrapping="true" />

                </expandedHeading>
                <actions>
                    <m:Button id="_IDGenButton10" icon="sap-icon://ai" press=".onAipress" tooltip="AI Assistant"></m:Button>
                </actions>

                <!-- SNAPPED -->
                <snappedHeading>

                    <m:FlexBox id="_IDGenFlexBox1" fitContainer="true" alignItems="Center">

                        <m:Avatar id="_IDGenAvatar1" src="sap-icon://process" backgroundColor="Accent6" class="sapUiTinyMarginEnd" />

                        <m:Title id="_IDGenTitle5" text="{headerDetails>/iFlowName}" wrapping="true" />

                    </m:FlexBox>

                </snappedHeading>

                <!-- EXPANDED CONTENT -->
                <expandedContent>

                    <m:ObjectStatus id="_IDGenObjectStatus" text="{headerDetails>/status}" state="{= ${headerDetails>/status} === 'OPEN'? 'Warning': ${headerDetails>/status} === 'RESOLVED'? 'Success': 'None'}" />

                </expandedContent>

                <!-- SNAPPED CONTENT -->
                <snappedContent>

                    <m:ObjectStatus id="_IDGenObjectStatus1" text="{headerDetails>/status}" state="{= ${headerDetails>/status} === 'OPEN'? 'Warning': ${headerDetails>/status} === 'RESOLVED'? 'Success': 'None'}" />

                </snappedContent>

                <!-- MOBILE -->
                <snappedTitleOnMobile>

                    <m:Title id="_IDGenTitle6" text="{headerDetails>/status}" />

                </snappedTitleOnMobile>

            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

        <headerContent>

            <m:FlexBox id="_IDGenFlexBox2" wrap="Wrap">

                <layout:VerticalLayout id="_IDGenVerticalLayout" class="sapUiSmallMarginBeginEnd">

                    <!-- <m:ObjectStatus title="iFlow Name" text="{headerDetails>/iFlowName}" /> -->

                    <m:ObjectStatus id="_IDGenObjectStatus2" title="Severity" text="{headerDetails>/severity}" />

                    <!-- <m:ObjectStatus title="Status" text="{headerDetails>/status}" /> -->

                    <!-- <m:ObjectStatus title="Error Type" text="{headerDetails>/errorSignature}" /> -->
                    <m:ObjectStatus id="_IDGenObjectStatus3" title="Incident Count" text="{headerDetails>/incidentCount}" />

                </layout:VerticalLayout>

                <layout:VerticalLayout id="_IDGenVerticalLayout1" class="sapUiSmallMarginBeginEnd">



                    <m:ObjectStatus id="_IDGenObjectStatus4" title="First Seen" text="{headerDetails>/firstSeen}" />

                    <m:ObjectStatus id="_IDGenObjectStatus5" title="Last Seen" text="{headerDetails>/lastSeen}" />

                </layout:VerticalLayout>

                <layout:VerticalLayout id="_IDGenVerticalLayout2" class="sapUiSmallMarginBeginEnd">

                    <m:ObjectStatus id="_IDGenObjectStatus6" title="Created By" text="{headerDetails>/createdBy}" />

                    <m:ObjectStatus id="_IDGenObjectStatus7" title="Modified By" text="{headerDetails>/modifiedBy}" />

                    <!-- <m:ObjectStatus title="Playbook ID" text="{headerDetails>/playbookId}" /> -->

                </layout:VerticalLayout>

            </m:FlexBox>

        </headerContent>

        <sections>

            <!-- ROOT CAUSE -->
            <ObjectPageSection id="_IDGenObjectPageSection" title="Root Cause Analysis" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection">

                        <blocks>

                            <m:VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                                <m:HBox id="_IDGenHBox1" alignItems="Center" class="sapUiTinyMarginBottom">

                                    <m:Avatar id="_IDGenAvatar2" initials="AI" displaySize="XS" class="sapUiTinyMarginEnd" />

                                    <m:Title id="_IDGenTitle7" text="Root Cause Analysis" level="H5" />

                                </m:HBox>

                                <m:Text id="_IDGenText6" wrapping="true" text="{details>/rootCause}" />

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>

            <!-- BUSINESS IMPACT -->
            <ObjectPageSection id="_IDGenObjectPageSection1" title="Business Impact" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection1">

                        <blocks>

                            <m:VBox id="_IDGenVBox2" class="sapUiSmallMargin">

                                <m:Title id="_IDGenTitle8" text="Business Impact" level="H5" class="sapUiTinyMarginBottom" />

                                <m:Text id="_IDGenText10" wrapping="true" text="{details>/businessImpact}" />

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>

            <ObjectPageSection id="_IDGenObjectPageSection2" title="Remediation Steps" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection2">

                        <blocks>

                            <m:VBox id="_IDGenVBox3" class="sapUiSmallMargin">

                                <m:Title id="_IDGenTitle9" text="Remediation Steps" level="H5" class="sapUiTinyMarginBottom" />

                                <suite:Timeline id="idRemediationTimeline" showIcons="false" showHeaderBar="false" enableScroll="false" content="{remediationSteps>/steps}">

                                    <suite:content>

                                        <suite:TimelineItem id="_IDGenTimelineItem" title="{remediationSteps>title}" text="{remediationSteps>text}" userNameClickable="false" />

                                    </suite:content>

                                </suite:Timeline>

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>


        </sections>
    </ObjectPageLayout>
</mvc:View>
 