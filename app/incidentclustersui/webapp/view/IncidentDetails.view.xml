<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.IncidentDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:suite="sap.suite.ui.commons"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:m="sap.m" height="100%">

    <ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="true" showFooter="true" upperCaseAnchorBar="false">
        <headerTitle>
            <ObjectPageDynamicHeaderTitle id="_IDGenObjectPageDynamicHeaderTitle">

                <!-- EXPANDED -->
                <expandedHeading>


                    <m:HBox id="_IDGenHBox2" alignItems="Center">

                        <m:Button id="_IDGenButton9" icon="sap-icon://nav-back" type="Default" press=".onNavBack" class="sapUiTinyMarginEnd" />

                        <m:Title id="_IDGenTitle4" text="{headerDetails>/errorType}" wrapping="true" />

                    </m:HBox>

                </expandedHeading>

                <actions>
                    <m:Button id="_IDGenButton10" icon="sap-icon://ai" type="Ghost" press=".onAipress" tooltip="AI Assistant"></m:Button>
                </actions>

                <!-- SNAPPED -->
                <snappedHeading>

                    <m:FlexBox id="_IDGenFlexBox1" fitContainer="true" alignItems="Center">

                        <m:Button id="_IDGenButton11" icon="sap-icon://nav-back" type="Transparent" press=".onNavBack" class="sapUiTinyMarginEnd" />

                        <m:Title id="_IDGenTitle5" text="{headerDetails>/errorType}" wrapping="true" />

                    </m:FlexBox>

                </snappedHeading>

                <!-- EXPANDED CONTENT -->
                <!-- <expandedContent>
 
                    <m:ObjectStatus id="_IDGenObjectStatus" text="{headerDetails>/status}" state="{= ${headerDetails>/status} === 'OPEN'? 'Warning': ${headerDetails>/status} === 'RESOLVED'? 'Success': 'None'}" />
 
                </expandedContent> -->

                <!-- SNAPPED CONTENT -->
                <!-- <snappedContent>
 
                    <m:ObjectStatus id="_IDGenObjectStatus1" text="{headerDetails>/status}" state="{= ${headerDetails>/status} === 'OPEN'? 'Warning': ${headerDetails>/status} === 'RESOLVED'? 'Success': 'None'}" />
 
                </snappedContent> -->

                <!-- MOBILE -->
                <snappedTitleOnMobile>

                    <m:Title id="_IDGenTitle6" text="{headerDetails>/errorType}" />

                </snappedTitleOnMobile>

            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

        <headerContent>

            <m:FlexBox id="_IDGenFlexBox2" wrap="Wrap" justifyContent="SpaceBetween" alignItems="Start" width="100%">
                <layout:HorizontalLayout id="_IDGenHorizontalLayout">
                    <layout:VerticalLayout id="_IDGenVerticalLayout" class="sapUiSmallMarginBeginEnd">

                        <!-- <m:ObjectStatus title="iFlow Name" text="{headerDetails>/errorType}" /> -->

                        <m:ObjectStatus id="_IDGenObjectStatus2" title="Severity" text="{headerDetails>/severity}" state="{= ${headerDetails>/severity} === 'CRITICAL' ? 'Error' : ${headerDetails>/severity} === 'HIGH' ? 'Warning' : ${headerDetails>/severity} === 'MEDIUM' ? 'Information' : ${headerDetails>/severity} === 'LOW' ? 'Success' : 'None' }" />
                        <!-- <m:ObjectStatus title="Status" text="{headerDetails>/status}" /> -->

                        <!-- <m:ObjectStatus title="Error Type" text="{headerDetails>/errorSignature}" /> -->
                        <m:ObjectStatus id="_IDGenObjectStatus3" title="Incident Count" text="{headerDetails>/incidentCount}" />

                        <m:ObjectStatus id="_IDGenObjectStatus" title="Confidence Score" />
                        <m:ProgressIndicator displayOnly="false" id="_IDGenProgressIndicator" percentValue="{details>/confidenceScore}" displayValue="{details>/confidenceScore}%" showValue="true" class="sapUiNoMarginTop" state="{= ${details>/confidenceScore} === null || !${details>/confidenceScore} ? 'None' : (${details>/confidenceScore} &lt;= 33 ? 'Error' : (${details>/confidenceScore} &lt;= 66 ? 'Warning' : 'Success')) }" />


                    </layout:VerticalLayout>

                    <layout:VerticalLayout id="_IDGenVerticalLayout1" class="sapUiSmallMarginBeginEnd">
                        <m:ObjectStatus id="_IDGenObjectStatus1" title="Status" text="{headerDetails>/status}" state="{= ${headerDetails>/status} === 'OPEN'? 'Warning': ${headerDetails>/status} === 'RESOLVED'? 'Success': 'None'}" />

                        <m:ObjectStatus id="_IDGenObjectStatus4" title="First Seen" text="{
                            path: 'headerDetails>/firstSeen',
                            formatter: '.formatter.formatDateTime'
                        }" />

                        <m:ObjectStatus id="_IDGenObjectStatus5" title="Last Seen" text="{
                            path: 'headerDetails>/lastSeen',
                            formatter: '.formatter.formatDateTime'
                        }"/>
                    </layout:VerticalLayout>

                    <!-- <layout:VerticalLayout id="_IDGenVerticalLayout2" class="sapUiSmallMarginBeginEnd">

                        <m:ObjectStatus id="_IDGenObjectStatus6" title="Created By" text="{headerDetails>/createdBy}" />

                        <m:ObjectStatus id="_IDGenObjectStatus7" title="Modified By" text="{headerDetails>/modifiedBy}" />

                    </layout:VerticalLayout> -->
                </layout:HorizontalLayout>
                <layout:VerticalLayout id="_IDGenVerticalLayout3" class="sapUiSmallMarginBeginEnd">
                    <m:ObjectNumber id="_IDGenObjectNumber" number="{= ${headerDetails>/totalTokenUsage} ? ${headerDetails>/totalTokenUsage} : 0 }" unit="Tokens used" emphasized="true" state="Information" class="sapMObjectNumberLarge"/>
                </layout:VerticalLayout>


            </m:FlexBox>

        </headerContent>

        <sections>

            <!-- ROOT CAUSE -->
            <ObjectPageSection id="_IDGenObjectPageSection" title="Root Cause Analysis" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection">

                        <blocks>

                            <m:VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                                <m:HBox id="_IDGenHBox1" alignItems="Center" class="sapUiTinyMarginBottom">

                                    <m:Avatar id="_IDGenAvatar2" src="sap-icon://inspection" displaySize="XS" class="sapUiTinyMarginEnd" />

                                    <m:Title id="_IDGenTitle7" text="Root Cause Analysis" level="H5" />

                                </m:HBox>

                                <m:Text id="_IDGenText6" wrapping="true" text="{details>/rootCause}" />

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>

            <!-- BUSINESS IMPACT -->
            <ObjectPageSection id="_IDGenObjectPageSection1" title="Business Impact" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection1">

                        <blocks>

                            <m:VBox id="_IDGenVBox2" class="sapUiSmallMargin">

                                <m:HBox id="_IDGenHBox3" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <m:Avatar id="_IDGenAvatar1" src="sap-icon://line-chart-time-axis" displaySize="XS" class="sapUiTinyMarginEnd" />

                                    <m:Title id="_IDGenTitle8" text="Business Impact" level="H5" />

                                </m:HBox>


                                <m:Text id="_IDGenText10" wrapping="true" text="{details>/businessImpact}" />

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>

            <ObjectPageSection id="_IDGenObjectPageSection2" title="Remediation Steps" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection2">

                        <blocks>

                            <m:VBox id="_IDGenVBox3" class="sapUiSmallMargin">

                                <m:HBox id="_IDGenHBox4" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <m:Avatar id="_IDGenAvatar3" src="sap-icon://technical-object" displaySize="XS" class="sapUiTinyMarginEnd" />

                                    <m:Title id="_IDGenTitle9" text="Remediation Steps" level="H5" />
                                </m:HBox>



                                <suite:Timeline width = "100%" id="idRemediationTimeline" showIcons="false" showHeaderBar="false" enableScroll="false" content="{remediationSteps>/steps}">

                                    <suite:content>

                                        <suite:TimelineItem id="_IDGenTimelineItem" status="Information" userName="{remediationSteps>title}" text="{remediationSteps>text}" userNameClickable="false" />
                                    </suite:content>


                                </suite:Timeline>

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>



            <ObjectPageSection title="Associated IFlows" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection3">

                        <blocks>

                            <m:VBox id="_IDGenVBox4" class="sapUiSmallMargin">

                                <m:HBox id="_IDGenHBox5" alignItems="Center" class="sapUiTinyMarginBottom">
                                    <m:Avatar id="_IDGenAvatar4" src="sap-icon://connected" displaySize="XS" class="sapUiTinyMarginEnd" />
                                    <m:Title id="_IDGenTitle10" text="Associated IFlows ({= ${headerDetails>/monitoredArtifacts}.length })" level="H5" />

                                </m:HBox>
                                <!-- <m:VBox id="_IDGenVBox5">
                                    <m:Text id="_IDGenText12" text="{incidentsModel>/incidents/0/errorMessage}" wrapping="true" />
                                </m:VBox> -->

                                <m:Table id="idIncidentTable" growing="true" growingScrollToLoad="false" growingThreshold="5" mode="None" items="{headerDetails>/monitoredArtifacts}">
                                    <!-- <m:headerToolbar>
                                        <m:OverflowToolbar id="_IDGenOverflowToolbar2">
                                            <m:Title id="_IDGenTitle11" level="H2" titleStyle="H2" text="Iflow Details"/>
                                        </m:OverflowToolbar>
                                    </m:headerToolbar> -->

                                    <m:columns>

                                        <m:Column id="_IDGenColumn" minScreenWidth="Tablet" demandPopin="true">
                                            <m:Text id="_IDGenText1" text="iFlow Name"/>
                                        </m:Column>

                                        <m:Column id="_IDGenColumn1" minScreenWidth="Tablet" demandPopin="true">
                                            <m:Text id="_IDGenText2" text="ID"/>
                                        </m:Column>

                                        <m:Column id="_IDGenColumn2" minScreenWidth="Tablet" demandPopin="true">
                                            <m:Text id="_IDGenText3" text="Last Poll"/>
                                        </m:Column>

                                        <m:Column id="_IDGenColumn3" minScreenWidth="Tablet" demandPopin="true">
                                            <m:Text id="_IDGenText4" text="Status"/>
                                        </m:Column>

                                    </m:columns>

                                    <m:items>

                                        <m:ColumnListItem id="_IDGenColumnListItem">

                                            <m:cells>
                                                <!-- ID -->
                                                <m:Text id="_IDGenText7" text="{headerDetails>artifact/ID}"/>
                                                <!-- iFlow Name -->
                                                <m:Text id="_IDGenText5" text="{headerDetails>artifact/iFlowName}"/>
                                                <!-- Last Poll -->
                                                <m:Text id="_IDGenText8" text="{
                                                        path: 'headerDetails>artifact/lastPollTimestamp',
                                                        formatter: '.formatter.formatDateTime'
                                                    }" />

                                                <!-- Active Status -->
                                                <m:ObjectStatus id="_IDGenObjectStatus9" text="{= ${headerDetails>artifact/isActive} ? 'Active' : 'Inactive' }" state="{= ${headerDetails>artifact/isActive} ? 'Success' : 'Error' }"/>

                                            </m:cells>

                                        </m:ColumnListItem>

                                    </m:items>

                                </m:Table>


                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>

            <ObjectPageSection title="Underlying Incidents" showTitle="false">

                <subSections>

                    <ObjectPageSubSection >

                        <blocks>

                            <m:VBox class="sapUiSmallMargin">

                                <m:HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                    <m:Avatar src="sap-icon://incident" displaySize="XS" class="sapUiTinyMarginEnd" />
                                    <m:Title text="Underlying Incidents ({headerDetails>/incidentCount})" level="H5" />

                                </m:HBox>

                                <m:VBox id="_IDGenVBox5">
                                    <m:Title text="Raw Error Message" level="H2" titleStyle="H2" class="sapUiTinyMarginBottom"/>
                                    <!-- <m:ObjectStatus text="Raw Error Message" state="Error" /> -->
                                    <m:Text id="_IDGenText12" text="    - {incidentsModel>/incidents/0/errorMessage}" wrapping="true" class="sapUiTinyMarginBegin"/>
                                </m:VBox>



                                <!-- <m:Table items="{headerDetails>/incidents}" growing="true" growingScrollToLoad="false" growingThreshold="5" mode="None">

                                    <m:columns>
                                        <m:Column>
                                            <m:Text text="iFlow Name"/>
                                        </m:Column>
                                        <m:Column>
                                            <m:Text text="Error Message"/>
                                        </m:Column>
                                        <m:Column>
                                            <m:Text text="Status"/>
                                        </m:Column>
                                    </m:columns>
                                    <m:items>
                                        <m:ColumnListItem>
                                            <m:cells>
                                                <m:Text text="{headerDetails>iFlowName}"/>
                                                <m:ExpandableText text="{headerDetails>errorMessage}"/>
                                                <m:ObjectStatus text="{headerDetails>status}" state="{= ${headerDetails>status} === 'FAILED' ? 'Error' : 'None' }"/>
                                            </m:cells>
                                        </m:ColumnListItem>
                                    </m:items>
                                </m:Table> -->

                            </m:VBox>

                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>


            <ObjectPageSection id="_IDGenObjectPageSection4" title="Playbook" visible="true" showTitle="false">

                <subSections>

                    <ObjectPageSubSection id="_IDGenObjectPageSubSection4">

                        <blocks>

                            <m:VBox id="_IDGenVBox6" class="sapUiSmallMargin">

                                <!-- Section Header: Clean spacing and bold title styling -->
                                <m:HBox id="_IDGenHBox6" alignItems="Center" class="sapUiSmallMarginBottom">
                                    <m:Avatar id="_IDGenAvatar5" src="sap-icon://education" displaySize="XS" displayShape="Square" class="sapUiTinyMarginEnd" />
                                    <m:Title id="_IDGenTitle12" text="Playbook" level="H4" titleStyle="H4" />
                                </m:HBox>

                                <!-- Main Title Card: Prominent, distinct header for the playbook name -->
                                <m:VBox id="_IDGenVBox9">
                                    <m:HBox id="_IDGenHBox8" alignItems="Center">
                                        <m:Title id="_IDGenTitle" text="{headerDetails>/playbook/title}" level="H2" titleStyle="H2"/>
                                        <m:ObjectStatus class="sapUiSmallMarginBegin" id="_IDGenObjectStatus8" text="{headerDetails>/playbook/severity}" inverted="true" state="{= ${headerDetails>/playbook/severity} === 'CRITICAL' ? 'Error' : ${headerDetails>/playbook/severity} === 'HIGH' ? 'Warning' : ${headerDetails>/playbook/severity} === 'MEDIUM' ? 'Information' : ${headerDetails>/playbook/severity} === 'LOW' ? 'Success' : 'None' }" />
                                    </m:HBox>

                                    <m:Text id="_IDGenText" text="{headerDetails>/playbook/description}" class="sapUiColorTextSecondary" />
                                </m:VBox>



                                <!-- Timeline Section: Minimalist timeline view -->
                                <suite:Timeline id="idRemediationTimelie" showIcons="false" showHeaderBar="false" enableScroll="false" content="{playbookSteps>/steps}">
                                    <suite:TimelineItem id="_IDGenTimelineIem" userName="{playbookSteps>title}" text="{playbookSteps>text}" userNameClickable="false" />
                                </suite:Timeline>

                            </m:VBox>


                        </blocks>

                    </ObjectPageSubSection>

                </subSections>

            </ObjectPageSection>


        </sections>


        <footer>

            <m:OverflowToolbar id="_IDGenOverflowToolbar1">

                <m:ToolbarSpacer id="_IDGenToolbarSpacer3" />

                <m:Button id="_IDGenButton12" visible="false" text="Re-diagnose" type="Attention" icon="sap-icon://ai" press="Rediagnose" />

                <m:Button id="_IDGenButton13" text="Resolve" type="Accept" icon="sap-icon://complete" press="onResolve" enabled="{= ${headerDetails>/status} === 'OPEN' }" />

            </m:OverflowToolbar>

        </footer>
    </ObjectPageLayout>
</mvc:View>
 
 