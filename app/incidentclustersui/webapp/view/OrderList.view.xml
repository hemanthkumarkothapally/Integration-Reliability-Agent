<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.OrderList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:card="sap.f.cards">

    <tnt:ToolPage id="toolPage1">

        <!-- ===================================================== -->
        <!-- HEADER -->
        <!-- ===================================================== -->

        <tnt:header >

            <tnt:ToolHeader id="_IDGenToolHeader1">

                <!-- MENU BUTTON -->

                <Button id="_IDGenButton3" icon="sap-icon://menu2" type="Transparent" press=".onSideNavButtonPress">

                    <layoutData>
                        <OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData" priority="NeverOverflow" />
                    </layoutData>

                </Button>

                <!-- SAP LOGO -->

                <!-- <Image src="https://www.sap.com/dam/application/shared/logos/sap-logo-svg.svg" width="4rem" /> -->

                <!-- TITLE -->

                <Title id="_IDGenTitle" text="Integration Monitoring Overview" level="H1" />

                <ToolbarSpacer id="_IDGenToolbarSpacer" />

                <!-- HEADER ACTIONS -->

                <!-- <Button icon="sap-icon://search" type="Transparent" />
 
                <Button icon="sap-icon://bell" type="Transparent" />
 
                <Button icon="sap-icon://question-mark" type="Transparent" />
 
                <Avatar initials="JP" backgroundColor="Accent6" /> -->

            </tnt:ToolHeader>

        </tnt:header>

        <!-- ===================================================== -->
        <!-- SIDE NAVIGATION -->
        <!-- ===================================================== -->

        <tnt:sideContent >

            <tnt:SideNavigation id="sideNavigation" >

                <tnt:NavigationList id="_IDGenNavigationList" >

                    <tnt:NavigationListItem id="_IDGenNavigationListItem" text="Overview" icon="sap-icon://home" key="overview" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem1" text="Incidents" icon="sap-icon://alert" key="incidents" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem2" text="iFlows" icon="sap-icon://process" key="iflows" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem3" text="Clusters" icon="sap-icon://share-2" key="clusters" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem4" text="Alerts" icon="sap-icon://bell" key="alerts" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem5" text="Reports" icon="sap-icon://document-text" key="reports" />

                    <tnt:NavigationListItem id="_IDGenNavigationListItem6" text="Settings" icon="sap-icon://action-settings" key="settings" />

                </tnt:NavigationList>

                <!-- FIXED FOOTER -->

                <tnt:fixedItem>

                    <tnt:NavigationList id="_IDGenNavigationList1">

                        <tnt:NavigationListItem id="_IDGenNavigationListItem7" text="Collapse" icon="sap-icon://collapse-group" select=".onSideNavButtonPress" />

                    </tnt:NavigationList>

                </tnt:fixedItem>

            </tnt:SideNavigation>

        </tnt:sideContent>

        <!-- ===================================================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================================================== -->

        <tnt:mainContents>

            <f:DynamicPage id="dynamicPage" toggleHeaderOnTitleClick="false">

                <!-- ===================================================== -->
                <!-- FILTER SECTION -->
                <!-- ===================================================== -->

                <f:header>

                    <f:DynamicPageHeader id="_IDGenDynamicPageHeader">

                        <f:content>

                            <fb:FilterBar id="filterbar" persistencyKey="incidentMonitoring" useToolbar="false" search=".onSearchiFlowName" filterChange=".onFilterChange" afterVariantLoad=".onAfterVariantLoad" class="sapUiTinyMargin">

                                <fb:filterGroupItems>

                                    <!-- ===================================================== -->
                                    <!-- IFLOW NAME -->
                                    <!-- ===================================================== -->

                                    <!-- <fb:FilterGroupItem name="iFlowName" label="iFlow Name" groupName="Group1" visibleInFilterBar="true">
 
                                        <fb:control>
 
                                            <MultiComboBox id="idIflowFilter" width="14rem" selectionChange=".onSelectionChange" items="{
                                    path:'/IncidentClusters'
                                }">
 
                                                <core:Item key="{iFlowName}" text="{iFlowName}" />
 
                                            </MultiComboBox>
 
                                        </fb:control>
 
                                    </fb:FilterGroupItem> -->

                                    <!-- ===================================================== -->
                                    <!-- SEVERITY -->
                                    <!-- ===================================================== -->

                                    <fb:FilterGroupItem id="_IDGenFilterGroupItem" name="Severity" label="Severity" groupName="Group1" visibleInFilterBar="true">

                                        <fb:control>

                                            <MultiComboBox id="idSeverityFilter" width="14rem">

                                                <core:Item id="_IDGenItem" key="CRITICAL" text="CRITICAL" />

                                                <core:Item id="_IDGenItem1" key="HIGH" text="HIGH" />

                                                <core:Item id="_IDGenItem2" key="MEDIUM" text="MEDIUM" />

                                                <core:Item id="_IDGenItem3" key="LOW" text="LOW" />

                                            </MultiComboBox>

                                        </fb:control>

                                    </fb:FilterGroupItem>

                                    <!-- ===================================================== -->
                                    <!-- STATUS -->
                                    <!-- ===================================================== -->

                                    <fb:FilterGroupItem id="_IDGenFilterGroupItem1" name="Status" label="Status" groupName="Group1" visibleInFilterBar="true">

                                        <fb:control>

                                            <MultiComboBox id="idStatusFilter" width="14rem">

                                                <core:Item id="_IDGenItem4" key="OPEN" text="OPEN" />

                                                <core:Item id="_IDGenItem5" key="RESOLVED" text="RESOLVED" />

                                            </MultiComboBox>

                                        </fb:control>

                                    </fb:FilterGroupItem>

                                    <!-- ===================================================== -->
                                    <!-- CLUSTER -->
                                    <!-- ===================================================== -->

                                    <!-- <fb:FilterGroupItem name="Cluster" label="Cluster" groupName="Group1" visibleInFilterBar="true">
 
                                        <fb:control>
 
                                            <MultiComboBox id="idClusterFilter" width="14rem">
 
                                                <core:Item key="DEV" text="DEV" />
 
                                                <core:Item key="QAS" text="QAS" />
 
                                                <core:Item key="PRD" text="PRD" />
 
                                            </MultiComboBox>
 
                                        </fb:control>
 
                                    </fb:FilterGroupItem> -->

                                </fb:filterGroupItems>

                            </fb:FilterBar>

                        </f:content>

                    </f:DynamicPageHeader>

                </f:header>

                <!-- ===================================================== -->
                <!-- PAGE CONTENT -->
                <!-- ===================================================== -->

                <f:content>

                    <!-- ===================================================== -->
                    <!-- KPI CARDS -->
                    <!-- ===================================================== -->
                    <VBox id="_IDGenVBox8">

                        <layout:Grid id="_IDGenGrid" defaultSpan="XL3 L3 M6 S12" hSpacing="1" vSpacing="1" class="sapUiSmallMarginBottom">

                            <layout:content>

                                <!-- ===================================================== -->
                                <!-- TOTAL INCIDENTS -->
                                <!-- ===================================================== -->

                                <f:Card id="_IDGenCard" width="100%" semanticRole="ListItem" class="sapUiTinyMarginEnd">

                                    <f:header>

                                        <card:NumericHeader id="_IDGenNumericHeader" title="Total Incidents " number="{dashboard>/totalIncidents24h}" state="Neutral" iconSrc="sap-icon://activity-items" />

                                    </f:header>



                                </f:Card>

                                <!-- ===================================================== -->
                                <!-- ACTIVE CLUSTERS -->
                                <!-- ===================================================== -->

                                <f:Card id="_IDGenCard1" width="100%" semanticRole="ListItem" class="sapUiTinyMarginEnd">

                                    <f:header>

                                        <card:NumericHeader id="_IDGenNumericHeader1" title="Active Clusters" number="{dashboard>/activeClusters}" state="Critical" iconSrc="sap-icon://bbyd-active-sales" />


                                    </f:header>


                                </f:Card>

                                <!-- ===================================================== -->
                                <!-- IFLOWS MONITORED -->
                                <!-- ===================================================== -->

                                <f:Card id="_IDGenCard2" width="100%" semanticRole="ListItem" class="sapUiTinyMarginEnd">

                                    <f:header>

                                        <card:NumericHeader id="_IDGenNumericHeader2" title="Critical" number="{dashboard>/criticalCount}" state="Error" iconSrc="sap-icon://alert" />


                                    </f:header>



                                </f:Card>

                                <!-- ===================================================== -->
                                <!-- RESOLVED TODAY -->
                                <!-- ===================================================== -->

                                <f:Card id="_IDGenCard3" width="100%" semanticRole="ListItem" class="sapUiTinyMarginEnd">

                                    <f:header>

                                        <card:NumericHeader id="_IDGenNumericHeader3" title="Resolved Today" number="{dashboard>/resolved24h}" state="Good" iconSrc="sap-icon://accept" />

                                    </f:header>



                                </f:Card>

                            </layout:content>
                        </layout:Grid>

                        <HBox id="_IDGenHBox8" class="sapUiMediumMarginEnd sapUiSmallMarginBegin" wrap="true" justifyContent="SpaceBetween">

                            <!-- ===================================================== -->
                            <!-- DONUT CHART CARD -->
                            <!-- ===================================================== -->

                            <f:Card id="_IDGenCard4" width="100%">
                                <f:layoutData>
                                    <FlexItemData id="_IDGenFlexItemData" growFactor=".5" baseSize="0"></FlexItemData>
                                </f:layoutData>

                                <f:header>

                                    <card:Header id="_IDGenHeader" title="Incidents by Severity" subtitle="Current distribution" iconSrc="sap-icon://donut-chart" />

                                </f:header>

                                <f:content>

                                    <!-- <viz:VizFrame id="idDonutChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="18rem">

                                        <viz:dataset>

                                            <viz.data:FlattenedDataset id="_IDGenFlattenedDataset" data="{chart>/severityData}">

                                                <viz.data:dimensions>

                                                    <viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Severity" value="{severity}" />

                                                </viz.data:dimensions>

                                                <viz.data:measures>

                                                    <viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="Count" value="{count}" />

                                                </viz.data:measures>

                                            </viz.data:FlattenedDataset>

                                        </viz:dataset>

                                        <viz:feeds>

                                            <viz.feeds:FeedItem id="_IDGenFeedItem" uid="size" type="Measure" values="Count" />

                                            <viz.feeds:FeedItem id="_IDGenFeedItem1" uid="color" type="Dimension" values="Severity" />

                                        </viz:feeds>

                                    </viz:VizFrame> -->
<viz:VizFrame
    id="topErrorTypesChart"
    vizType="bar"
    width="100%"
    height="18rem"
    vizProperties="{
        'plotArea': {
            'dataLabel': { 'visible': true },
            'gap': 0.5
        },
        'legend': { 'visible': false },
        'title':  { 'visible': false },
        'categoryAxis': {
            'title': { 'visible': false },
            'label': { 'angle': 30 }
        },
        'valueAxis': {
            'title': { 'visible': true, 'text': 'Incident count' }
        }
    }">

        <viz:dataset>
            <viz.data:FlattenedDataset
                data="{topErrors>/data}">
                <viz.data:dimensions>
                    <viz.data:DimensionDefinition
                        name="Error Type"
                        value="{topErrors>errorType}" />
                </viz.data:dimensions>
                <viz.data:measures>
                    <viz.data:MeasureDefinition
                        name="Incidents"
                        value="{topErrors>count}" />
                </viz.data:measures>
            </viz.data:FlattenedDataset>
        </viz:dataset>

        <viz:feeds>
            <viz.feeds:FeedItem
                uid="valueAxis"
                type="Measure"
                values="Incidents" />
            <viz.feeds:FeedItem
                uid="categoryAxis"
                type="Dimension"
                values="Error Type" />
        </viz:feeds>

    </viz:VizFrame>
                                </f:content>

                            </f:Card>

                            <!-- ===================================================== -->
                            <!-- LINE CHART CARD -->
                            <!-- ===================================================== -->

                            <f:Card id="_IDGenCard5" width="100%" class="sapUiSmallMarginBegin">
                                <f:layoutData>
                                    <FlexItemData id="_IDGenFlexItemData2" growFactor=".5" baseSize="0"></FlexItemData>
                                </f:layoutData>


                                <f:header>

                                    <card:Header id="_IDGenHeader1" title="Incidents Trend" subtitle="Last 7 Days" iconSrc="sap-icon://line-chart" />

                                </f:header>

                                <f:content>

                                  <viz:VizFrame
    id="idLineChart"
    uiConfig="{applicationSet:'fiori'}"
    vizType="dual_line"
    width="100%"
    height="18rem">

    <viz:dataset>

        <viz.data:FlattenedDataset
            data="{chart>/trendData}">

            <viz.data:dimensions>

                <viz.data:DimensionDefinition
                    name="Day"
                    value="{chart>DAY}" />

            </viz.data:dimensions>

            <viz.data:measures>

                <viz.data:MeasureDefinition
                    name="Incidents"
                    value="{chart>INCIDENTCOUNT}" />

                <viz.data:MeasureDefinition
                    name="Clusters"
                    value="{chart>CLUSTERCOUNT}" />

            </viz.data:measures>

        </viz.data:FlattenedDataset>

    </viz:dataset>

    <viz:feeds>

        <viz.feeds:FeedItem
            uid="valueAxis"
            type="Measure"
            values="Incidents" />

        <viz.feeds:FeedItem
            uid="valueAxis2"
            type="Measure"
            values="Clusters" />

        <viz.feeds:FeedItem
            uid="categoryAxis"
            type="Dimension"
            values="Day" />

    </viz:feeds>

</viz:VizFrame>



                                </f:content>

                            </f:Card>
                            <viz:Popover id="idPopOver" />

                        </HBox>

                        <!-- ===================================================== -->
                        <!-- INCIDENT TABLE SECTION -->
                        <!-- ===================================================== -->

                        <Panel id="_IDGenPanel" width="100%" class="sapUiMediumMarginBottom sapUiMediumMarginTop">

                            <!-- ===================================================== -->
                            <!-- ICON TAB BAR -->
                            <!-- ===================================================== -->

                            <IconTabHeader id="idSeverityTabBar" expandable="false" select=".onSeverityTabSelect" class="sapUiResponsiveContentPadding">

                                <items>

                                    <!-- ALL -->

                                    <IconTabFilter id="_IDGenIconTabFilter" key="ALL" text="All" iconColor="Neutral" icon="sap-icon://list" />

                                    <!-- CRITICAL -->

                                    <IconTabFilter id="_IDGenIconTabFilter1" key="CRITICAL" text="Critical" icon="sap-icon://message-error" iconColor="Negative" />

                                    <!-- HIGH -->

                                    <IconTabFilter id="_IDGenIconTabFilter2" key="HIGH" text="High" icon="sap-icon://alert" iconColor="Critical" />

                                    <!-- MEDIUM -->

                                    <IconTabFilter id="_IDGenIconTabFilter3" key="MEDIUM" text="Medium" icon="sap-icon://information" iconColor="Default" />

                                    <!-- LOW -->

                                    <IconTabFilter id="_IDGenIconTabFilter4" key="LOW" text="Low" icon="sap-icon://accept" iconColor="Positive" />

                                </items>


                            </IconTabHeader>
                            <!-- ===================================================== -->
                            <!-- TABLE -->
                            <!-- ===================================================== -->

                            <Table id="idIncidentClustersTable" inset="false" width="100%" growing="true" growingScrollToLoad="true" mode="None" sticky="ColumnHeaders,HeaderToolbar" items="{
            path:'/IncidentClusters'
        }">

                                <!-- HEADER TOOLBAR -->

                                <headerToolbar>

                                    <OverflowToolbar id="_IDGenOverflowToolbar">

                                        <Title id="_IDGenTitle11" text="Incident Clusters" level="H3" />

                                        <ToolbarSpacer id="_IDGenToolbarSpacer4" />

                                    </OverflowToolbar>

                                </headerToolbar>

                                <!-- COLUMNS -->

                                <columns>

                                    <Column id="_IDGenColumn" width="6rem">
                                        <Text id="_IDGenText1" text="Count" />
                                    </Column>

                                    <Column id="_IDGenColumn1" minScreenWidth="Tablet" demandPopin="true">

                                        <Text id="_IDGenText2" text="Message" />
                                    </Column>

                                    <Column id="_IDGenColumn2" width="10rem">
                                        <Text id="_IDGenText3" text="Severity" />
                                    </Column>

                                    <Column id="_IDGenColumn3" width="8rem">
                                        <Text id="_IDGenText4" text="Status" />
                                    </Column>

                                    <Column id="_IDGenColumn4" width="14rem">
                                        <Text id="_IDGenText5" text="Last Seen" />
                                    </Column>

                                </columns>

                                <!-- ITEMS -->

                                <items>

                                    <ColumnListItem id="_IDGenColumnListItem" type="Navigation" press=".onRowPress">

                                        <cells>

                                            <!-- COUNT -->

                                            <ObjectNumber id="_IDGenObjectNumber" number="{incidentCount}" emphasized="true" state="{
                            path:'severity',
                            formatter:'.formatter.formatNumberState'
                        }" />

                                            <!-- MESSAGE -->

                                            <Text id="_IDGenText7" text="{errorType}" wrapping="false" />

                                            <!-- SEVERITY -->

                                            <ObjectStatus id="_IDGenObjectStatus8" text="{severity}" state="{
                            path:'severity',
                            formatter:'.formatter.formatSeverityState'
                        }" />

                                            <!-- STATUS -->

                                            <ObjectStatus id="_IDGenObjectStatus9" text="{status}" state="{
                            path:'status',
                            formatter:'.formatter.formatStatusState'
                        }" />

                                            <!-- LAST SEEN -->

                                            <Text id="_IDGenText8" text="{lastSeen}" />

                                        </cells>

                                    </ColumnListItem>

                                </items>

                            </Table>

                        </Panel>
                    </VBox>



                </f:content>

            </f:DynamicPage>

        </tnt:mainContents>

    </tnt:ToolPage>
</mvc:View>
 