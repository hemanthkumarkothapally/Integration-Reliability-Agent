<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Monitored_iflows"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" preserveHeaderStateOnScroll="true" toggleHeaderOnTitleClick="false">


        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <items>
                            <Button icon="sap-icon://nav-back" type="Ghost" press=".onNavBackToOverview" class="sapUiSmallMarginEnd"/>
                            <Title text="Monitoring IFlows" wrapping="true" />
                        </items>
                    </HBox>
                </f:heading>

                <!-- <f:expandedContent>
                    <Label text="Monitor your iFlows &amp; Associated Clusters" class="sapUiSmallMarginBegin" />
                </f:expandedContent> -->

                <f:actions>
                    <Button icon="sap-icon://ai" text="Ai Assistant" type="Ghost" press=".onAipress" tooltip="AI Assistant"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <FlexBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="sapUiSmallMarginTop">
                        <items>

                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idIFlowFilter" width="100%" placeholder="Filter by IFlow Name" items="{path:'/MonitoredArtifacts'}" selectionChange=".onFilterChange">
                                        <core:Item key="{iFlowName}" text="{iFlowName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <DateRangeSelection id="idDateRangeFilter" width="100%" placeholder="Select Date Range" change=".onFilterChange" />
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idpackageFilter" width="100%" placeholder="Filter by Package Name" items="{
                                        path: '/MonitoredArtifacts',
                                        parameters: {
                                            $apply: 'groupby((PackageName))'
                                        }
                                    }" selectionChange=".onFilterChange">
                                        <core:Item key="{PackageName}" text="{PackageName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idTenantFilter" width="100%" placeholder="Filter by Tenant" items="{path:'/Tenants'}" selectionChange=".onFilterChange">
                                        <core:Item key="{ID}" text="{tenantName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>


                            <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>

                                    <Button icon="sap-icon://error" text="{= 'Critical' }" type="Reject" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="CRITICAL" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://warning" text="{= 'High' }" type="Attention" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="HIGH" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://information" text="{= 'Medium' }" type="Neutral" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="MEDIUM" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://incident" text="{= 'Low' }" type="Accept" press=".onTagPress" class="sapUiTinyMarginBottom sapUiTinyMarginEnd">
                                        <customData>
                                            <core:CustomData key="severity" value="LOW" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://process" text="{= 'All' }" type="Ghost" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="ALL" />
                                        </customData>
                                    </Button>
                                    <Button text="Clear Filters" icon="sap-icon://clear-filter" type="Transparent" press=".onClearFilters" />
                                </items>
                            </FlexBox>

                        </items>
                    </FlexBox>
                </f:content>

            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:VerticalLayout width="100%">
                <MessageStrip enableFormattedText="true" text="Click any &lt;strong&gt;iFlow row&lt;/strong&gt; to open the &lt;strong&gt;Detail View&lt;/strong&gt; with all associated clusters and recent incidents." type="Information" showIcon="true" showCloseButton="true" class="sapUiSmallMarginBottom" />

                <Table id="idMonitoredArtifacts" updateFinished=".onTableUpdateFinished" growing="true" growingThreshold="30" growingScrollToLoad="true" mode="SingleSelectMaster" itemPress=".onRowPress" items="{
            path: '/MonitoredArtifacts',
            parameters: {
            $count: true
        },
            sorter: { path: 'lastErrorAt', descending: true }
        }">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title id = "idTableTitle" text="{= 'Monitored iFlows (' + ${/MonitoredArtifacts/$count} + ')' }" level="H4"/>

                            <ToolbarSpacer />

                            <Text text="Last updated: {globalModel>/lastRefreshTime}" class="sapUiSmallMarginEnd" />

                            <Button icon="sap-icon://refresh" tooltip="Refresh Data" press=".onRefreshPress" type="Transparent" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="3rem" hAlign="Center" />
                        <Column width="40%" demandPopin="true">
                            <Text text="iFlow Name" />
                        </Column>
                        <Column width="20%" hAlign="Begin" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Package" />
                        </Column>
                        <Column width="10%" hAlign="Begin" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Severity" />
                        </Column>
                        <Column width="10%" hAlign="Center" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Active Clusters" />
                        </Column>
                        <Column width="20%" hAlign="End" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Last Failure" />
                        </Column>

                    </columns>

                    <items>
                        <ColumnListItem type="Navigation">
                            <cells>
                                <core:Icon src="sap-icon://process" size="1.25rem" color="{path: 'overallSeverity', formatter: '.formatter.severityIconColor'}"/>

                                <Title text="{iFlowName}" titleStyle="H6" wrapping="true" />
                                <Text text="{PackageName}" />
                                <Button text="{path: 'overallSeverity', formatter: '.formatter.formatButtonText'}" type="{path: 'overallSeverity', formatter: '.formatter.formatButtonState'}" icon="{path: 'overallSeverity', formatter: '.formatter.formatSeverityIcon'}" class="unclickableTag">
                                    <customData>
                                        <core:CustomData key="severity" value="{overallSeverity}" />
                                    </customData>
                                </Button>
                                <ObjectNumber number="{openClusterCount}" emphasized="true" state="{path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}"/>
                                <Text text="{path: 'lastErrorAt', formatter: '.formatter.formatDateTime'}" />

                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </layout:VerticalLayout>

        </f:content>

    </f:DynamicPage>
</mvc:View>
