<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Overview" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:card="sap.f.cards">

    <tnt:ToolPage id="toolPage1"  sideExpanded="false">


        <tnt:header >

            <tnt:ToolHeader>

                <!-- MENU BUTTON -->

                <Button icon="sap-icon://menu2" type="Transparent" press=".onSideNavButtonPress">

                    <layoutData>
                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                    </layoutData>

                </Button>

                <Title text="Integration Monitoring Overview" level="H1" />

                <ToolbarSpacer />
                <Button icon="sap-icon://process" text="iFlows" type="Ghost" press=".onIFlowBtn" tooltip="Navigate to iFlows Page"/>


            </tnt:ToolHeader>

        </tnt:header>

        <!-- ===================================================== -->
        <!-- SIDE NAVIGATION -->
        <!-- ===================================================== -->

        <!-- <tnt:sideContent>

            <tnt:SideNavigation id="sideNavigation">

                <tnt:NavigationList  itemSelect=".onSideNavigationSelect">

                    <tnt:NavigationListItem text="Overview" icon="sap-icon://home" key="overview" />

                    <tnt:NavigationListItem text="Incidents" icon="sap-icon://alert" key="incidents" />

                    <tnt:NavigationListItem text="iFlows" icon="sap-icon://process" key="iflows" />

                    <tnt:NavigationListItem text="Clusters" icon="sap-icon://share-2" key="clusters" />

                </tnt:NavigationList>


            </tnt:SideNavigation>

        </tnt:sideContent> -->

        <!-- ===================================================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================================================== -->

        <tnt:mainContents>

            <f:DynamicPage id="dynamicPage" fitContent="true" toggleHeaderOnTitleClick="false">


                <!-- ===================================================== -->
                <!-- PAGE CONTENT -->
                <!-- ===================================================== -->

                <f:content >

                    <!-- ===================================================== -->
                    <!-- KPI CARDS -->
                    <!-- ===================================================== -->

                    <VBox class="sapUiNoMargin">
                        <f:GridList id="kpiGridList" width="100%" growing="false">

                            <f:customLayout>
                                <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(14rem, 1fr))" gridGap="0.5rem" />
                            </f:customLayout>

                            <f:items>

                                <!-- Total Incidents -->
                                <f:GridListItem >
                                    <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Monitored iFlows" number="{chart>/monitoredIflows}" state="Neutral" iconSrc="sap-icon://process" />
                                        </f:header>
                                    </f:Card>
                                    
                                </f:GridListItem>

                                <!-- Active Clusters -->
                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Open Clusters" number="{chart>/openClusters}" state="Critical" iconSrc="sap-icon://group-2" />
                                        </f:header>
                                    </f:Card>
                                </f:GridListItem>

                                <!-- Critical -->
                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Open Incidents" number="{chart>/openIncidents}" state="Error" iconSrc="sap-icon://message-warning" />
                                        </f:header>
                                    </f:Card>
                                </f:GridListItem>

                                <!-- Critical Iflows -->
                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Critical Iflows" number="{chart>/criticalIflows}" state="Good" iconSrc="sap-icon://status-critical" />
                                        </f:header>
                                    </f:Card>
                                </f:GridListItem>

                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Clusters Resolved Today" number="{chart>/resolvedToday}" state="Good" iconSrc="sap-icon://complete" />
                                        </f:header>
                                    </f:Card>
                                </f:GridListItem>
                            </f:items>

                        </f:GridList>

                        <f:GridList width="100%">

                            <f:customLayout>
                                <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(16rem, 1fr))" gridGap="0.5rem" />
                            </f:customLayout>

                            <f:items>

                                <!-- Top Error Types -->
                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Incidents by Error Type" subtitle="Top 5 Clusters in the last 24 hours" iconSrc="sap-icon://donut-chart" />
                                        </f:header> -->

                                        <f:content >
                                            <viz:VizFrame id="topErrorTypesChart"  uiConfig="{applicationSet:'fiori'}" vizType="donut" vizProperties="{
                                                'title': {
                                                    'visible': true,
                                                    'text': 'Clusters by Severity'
                                                },
                                                'legend': {
                                                    'visible': true
                                                },
                                                'plotArea': {
                                                    'dataLabel': {
                                                        'visible': true
                                                    }
                                                }
                                            }" width="100%" height="18rem">

                                                <viz:dataset >

                                                    <viz.data:FlattenedDataset data="{chart>/clusterSeverity}">

                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                        </viz.data:measures>

                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>


                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />

                                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                                </viz:feeds>

                                            </viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                                <!-- Incident Trend -->
                                <f:GridListItem >
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Incidents Trend" subtitle="Last 7 Days" iconSrc="sap-icon://line-chart" />
                                        </f:header> -->

                                        <f:content>
                                            <viz:VizFrame id="idLineChart" vizType="dual_line" uiConfig="{applicationSet:'fiori'}" width="100%" height="18rem" vizProperties="{'title': {
                                                    'visible': true,
                                                    'text': 'Incidents Over Time'
                                                },
                                                'legend': {
                                                    'visible': true
                                                },
                                                'plotArea': {
                                                    'dataLabel': {
                                                        'visible': true
                                                    }
                                                }
                                            }">

                                                <viz:dataset>
                                                    <viz.data:FlattenedDataset data="{chart>/incidentTrend}">

                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Time" value="{chart>hour}" />
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Total Incidents" value="{chart>totalIncidents}" />

                                                            <viz.data:MeasureDefinition name="Open Incidents" value="{chart>openIncidents}" />
                                                        </viz.data:measures>

                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>

                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Total Incidents"/>

                                                    <viz.feeds:FeedItem uid="valueAxis2" type="Measure" values="Open Incidents"/>

                                                    <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Time"/>
                                                </viz:feeds>

                                            </viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Severity Distribution" subtitle="Current Open Clusters" iconSrc="sap-icon://pie-chart" />
                                        </f:header> -->

                                        <f:content>
                                            <viz:VizFrame id="severityChart" vizType="donut" width="100%" height="18rem" uiConfig="{applicationSet:'fiori'}" vizProperties="{
                                                'title': {
                                                    'visible': true,
                                                    'text': 'IFlows by Severity'
                                                },
                                                'legend': {
                                                    'visible': true
                                                },
                                                'plotArea': {
                                                    'dataLabel': {
                                                        'visible': true
                                                    }
                                                }
                                            }">

                                                <viz:dataset>
                                                    <viz.data:FlattenedDataset data="{chart>/iflowSeverity}">

                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                        </viz.data:measures>



                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>

                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />

                                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                                </viz:feeds>

                                            </viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                            </f:items>

                        </f:GridList>

                        <viz:Popover id="idPopOver"/>

                        <!-- ===================================================== -->
                        <!-- TOP PROBLEMATIC IFLOWS -->
                        <!-- ===================================================== -->

                        <f:Card semanticRole="ListItem" width="100%">

                            <f:header>
                                <card:Header title="Top 5 Problematic iFlows" />
                            </f:header>

                            <f:content>

                                <Table id="topIflowsTable" items="{topIflows>/topIflows}" autoPopinMode="true" sticky="ColumnHeaders">

                                    <columns>
                                        <Column width="3rem" hAlign="Center" />

                                        <Column width="18rem">
                                            <Text text="iFlow Name" />
                                        </Column>

                                         <Column minScreenWidth="Tablet">
                                            <Text text="Package Name" />
                                        </Column>

                                        <Column minScreenWidth="Tablet">
                                            <Text text="Severity" />
                                        </Column>

                                        <Column minScreenWidth="Tablet" hAlign="Center">
                                            <Text text="Open Clusters" />
                                        </Column>

                                        <Column minScreenWidth="Tablet" hAlign="Center">
                                            <Text text="Open Incidents" />
                                        </Column>

                                        <Column minScreenWidth="Desktop">
                                            <Text text="Last Failure" />
                                        </Column>

                                    </columns>

                                    <items>

                                        <ColumnListItem type="Navigation" press="onTopIflowPress">

                                            <cells>
                                                <core:Icon src="sap-icon://process" size="1.25rem" color="{path: 'topIflows>overallSeverity', formatter: '.formatter.severityIconColor'}"/>
                                                <Text text="{topIflows>iFlowName}" />
                                                 <Text text="{topIflows>PackageName}" />

                                                <ObjectStatus text="{topIflows>overallSeverity}" state="{
        path: 'topIflows>overallSeverity',
        formatter: '.formatter.formatSeverityState'
    }" />

                                                <ObjectNumber number="{topIflows>openClusterCount}" />

                                                <ObjectNumber number="{topIflows>totalIncidents}" emphasized="true" />

                                               <Text text="{path: 'topIflows>lastPollTimestamp', formatter: '.formatter.formatDateTime'}" />

                                            </cells>

                                        </ColumnListItem>

                                    </items>

                                </Table>

                            </f:content>

                        </f:Card>
                    </VBox >
                    <!-- ===================================================== -->
                    <!-- INCIDENT TABLE SECTION -->
                    <!-- ===================================================== -->






                </f:content>

            </f:DynamicPage>

        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>