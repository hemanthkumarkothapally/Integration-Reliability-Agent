<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Add Tenant"
        contentWidth="500px">

        <VBox class="sapUiMediumMargin">

            <Label text="Tenant Name" required="true"/>
            <Input id="tenantNameInput" value="{globalModel>/TenantDetails/tenantName}"/>

            <Label text="Tenant ID" required="true"/>
            <Input id="tenantIdInput" value="{globalModel>/TenantDetails/tenantId}"/>

            <Label text="Destination Name" required="true"/>
            <ComboBox id="destinationInput" selectedKey="{globalModel>/TenantDetails/destinationName}" change=".onDestinationChange" width="100%" items="{globalModel>/destinations}">
            <items>
            <core:Item text="{globalModel>Name}" key="{globalModel>Name}" ></core:Item>
            </items>
            </ComboBox>

            <Label text="URL" required="true"/>
            <Input id="urlInput" value="{globalModel>/TenantDetails/url}" editable="false"/>
            <Label text="Active" required="true"/>
            <Switch id="activeSwitch" state="{globalModel>/TenantDetails/isActive}"/>

        </VBox>

        <beginButton>
            <Button
                text="Create"
                type="Emphasized"
                press=".onCreateTenant"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCloseTenantDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>