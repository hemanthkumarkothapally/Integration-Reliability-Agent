<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Overview" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:card="sap.f.cards">

    

            <f:DynamicPage id="dynamicPage" fitContent="false" toggleHeaderOnTitleClick="false">


                <!-- ===================================================== -->
                <!-- PAGE CONTENT -->
                <!-- ===================================================== -->

                <f:content >

                    <!-- ===================================================== -->
                    <!-- KPI CARDS -->
                    <!-- ===================================================== -->

                    <VBox class="sapUiNoMargin">
                    <Text text="Tenant:"></Text>
               <Select
    id="tenantSelect"
    selectedKey="ALL"
    change=".onTenantChange"
    items="{tenantModel>/tenants}">

    <core:Item
        key="{tenantModel>ID}"
        text="{tenantModel>tenantName}" />

</Select>
                        <f:GridList id="kpiGridList" class="sapUiTinyMarginBottom" width="100%" growing="false">

                            <f:customLayout>
                                <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(16rem, 1fr))" gridGap="1rem" />
                            </f:customLayout>

                            <f:items>

                                <!-- Total Incidents -->
                                <f:GridListItem>
                                    <!-- <f:Card width="100%" semanticRole="ListItem"> -->
                                    <!-- <f:header>
                                            <card:NumericHeader title="Monitored iFlows" number="{chart>/monitoredIflows}" state="Neutral" iconSrc="sap-icon://process" />
                                        </f:header> -->

                                    <!-- <f:content> -->
                                    <HBox width="100%" height="10vh" alignItems="Center" justifyContent="Start" class="sapUiSmallMargin">

                                        <!-- Icon Circle -->
                                        <VBox class="iconCircle blueIconBg" justifyContent="Center" alignItems="Center">

                                            <core:Icon src="sap-icon://process" size="1.4rem" color="#2563EB"/>
                                        </VBox>

                                        <!-- KPI Content -->
                                        <VBox class="sapUiSmallMarginBegin">
                                            <Title text="Monitored iFlows" level="H5" class="kpiTitle"/>
                                                
                                            <Text text="{chart>/monitoredIflows}" class="kpiValueBlue"/>
                                        </VBox>

                                    </HBox>
                                    <!-- </f:content> -->
                                    <!-- </f:Card> -->

                                </f:GridListItem>

                                <!-- Active Clusters -->
                                <f:GridListItem>
                                    <!-- <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Open Clusters" number="{chart>/openClusters}" state="Critical" iconSrc="sap-icon://group-2" />
                                        </f:header>
                                    </f:Card> -->

                                    <HBox width="100%" height="10vh" alignItems="Center" class="sapUiSmallMargin">

                                        <VBox class="iconCircle orangeIconBg" justifyContent="Center" alignItems="Center">

                                            <core:Icon src="sap-icon://group-2" size="1.4rem" color="#EA580C"/>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin">
                                            <Title text="Open Clusters" level="H5" class="kpiTitle"/>
                                            <Text text="{chart>/openClusters}" class="kpiValueOrange"/>
                                        </VBox>

                                    </HBox>
                                </f:GridListItem>

                                <!-- Critical -->
                                <f:GridListItem>
                                    <!-- <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Open Incidents" number="{chart>/openIncidents}" state="None" iconSrc="sap-icon://message-warning" />
                                        </f:header>
                                    </f:Card> -->

                                    <HBox width="100%" height="10vh" alignItems="Center" class="sapUiSmallMargin">

                                        <VBox class="iconCircle yellowIconBg" justifyContent="Center" alignItems="Center">

                                            <core:Icon src="sap-icon://message-warning" size="1.4rem" color="#D97706"/>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin">
                                            <Title text="Open Incidents" level="H5" class="kpiTitle"/>
                                            <Text text="{chart>/openIncidents}" class="kpiValueYellow"/>
                                        </VBox>

                                    </HBox>
                                </f:GridListItem>

                                <!-- Critical Iflows -->
                                <f:GridListItem>
                                    <!-- <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Critical Iflows" number="{chart>/criticalIflows}" state="Error" iconSrc="sap-icon://status-critical" />
                                        </f:header>
                                    </f:Card> -->

                                    <HBox width="100%" height="10vh" alignItems="Center" class="sapUiSmallMargin">

                                        <VBox class="iconCircle redIconBg" justifyContent="Center" alignItems="Center">

                                            <core:Icon src="sap-icon://status-critical" size="1.4rem" color="#DC2626"/>
                                        </VBox>

                                        <VBox class="sapUiSmallMarginBegin">
                                            <Title text="Critical iFlows" level="H5" class="kpiTitle"/>
                                            <Text text="{chart>/criticalIflows}" class="kpiValueRed"/>
                                        </VBox>

                                    </HBox>
                                </f:GridListItem>

                                <f:GridListItem>
                                    <!-- <f:Card width="100%" semanticRole="ListItem">
                                        <f:header>
                                            <card:NumericHeader title="Clusters Resolved Today" number="{chart>/resolvedToday}" state="Good" iconSrc="sap-icon://complete" />
                                        </f:header>
                                    </f:Card> -->
                                    <HBox width="100%" height="10vh" alignItems="Center" class="sapUiSmallMargin">

                                        <VBox class="iconCircle greenIconBg" justifyContent="Center" alignItems="Center">

                                            <core:Icon src="sap-icon://complete" size="1.4rem" color="#16A34A"/>
                                        </VBox>

                                        <VBox wrap="Wrap" class="sapUiSmallMarginBegin">
                                            <Title text="Resolved Clusters Today" level="H5" wrapping="true" class="kpiTitle"/>
                                            <Text text="{chart>/resolvedToday}" class="kpiValueGreen"/>
                                        </VBox>

                                    </HBox>
                                </f:GridListItem>
                            </f:items>

                        </f:GridList>

                        <f:GridList class="sapUiTinyMarginBottom" width="100%">

                            <f:customLayout>
                                <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(16rem, 1fr))" gridGap="1rem" />
                            </f:customLayout>

                            <f:items>

                                <!-- Top Error Types -->
                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Incidents by Error Type" subtitle="Top 5 Clusters in the last 24 hours" iconSrc="sap-icon://donut-chart" />
                                        </f:header> -->

                                        <f:content >
                                            <viz:VizFrame id="topErrorTypesChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" vizProperties="{
        'title': {
            'visible': true,
            'text': 'Clusters by Severity'
        },
        'legend': {
            'visible': true
        },
        'plotArea': {
            'dataLabel': {
                'visible': true
            },
            'colorPalette': [
                                                            '#e60000',
                                                            '#f28c00',
                                                            '#f4c20d',
                                                            '#00a651'
                                                        ],
              'drawingEffect': 'glossy'
        }
    }" width="100%" height="18rem">

                                                <viz:dataset >

                                                    <viz.data:FlattenedDataset data="{chart>/clusterSeverity}">

                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                        </viz.data:measures>

                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>


                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />

                                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                                </viz:feeds>

                                            </viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                                <!-- Incident Trend -->
                                <f:GridListItem >
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Incidents Trend" subtitle="Last 7 Days" iconSrc="sap-icon://line-chart" />
                                        </f:header> -->

                                        <f:content>
                                            <viz:VizFrame id="idLineChart" 
    vizType="area" 
    uiConfig="{applicationSet:'fiori'}" 
    width="100%" 
    height="18rem" 
    vizProperties="{
        'title': {
            'visible': true,
            'text': 'Incidents Over Time'
        },
        'legend': {
            'visible': true,
            'position': 'top',
            'alignment': 'start'
        },
        'plotArea': {
            'dataLabel': {
                'visible': true
            },
            'colorPalette': ['#1565C0', '#E53935'],
            'drawingEffect': 'glossy',
            'window': {
                'start': 'firstDataPoint',
                'end': 'lastDataPoint'
            }
        },
        'valueAxis': {
            'title': { 'visible': false }
        },
        'categoryAxis': {
            'title': { 'visible': false }
        }
    }">

    <viz:dataset>
        <viz.data:FlattenedDataset data="{chart>/incidentTrend}">
            <viz.data:dimensions>
                <viz.data:DimensionDefinition name="Time" value="{chart>hour}" />
            </viz.data:dimensions>
            <viz.data:measures>
                <viz.data:MeasureDefinition name="Total Incidents" value="{chart>totalIncidents}" />
                <viz.data:MeasureDefinition name="Open Incidents" value="{chart>openIncidents}" />
            </viz.data:measures>
        </viz.data:FlattenedDataset>
    </viz:dataset>

    <viz:feeds>
        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Total Incidents,Open Incidents"/>
        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Time"/>
    </viz:feeds>

</viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                                <f:GridListItem>
                                    <f:Card width="100%" semanticRole="ListItem" height="100%">
                                        <!-- <f:header>
                                            <card:Header title="Severity Distribution" subtitle="Current Open Clusters" iconSrc="sap-icon://pie-chart" />
                                        </f:header> -->

                                        <f:content>
                                            <viz:VizFrame id="severityChart" vizType="donut" width="100%" height="18rem" uiConfig="{applicationSet:'fiori'}" vizProperties="{
                                                'title': {
                                                    'visible': true,
                                                    'text': 'IFlows by Severity'
                                                },
                                                'legend': {
                                                    'visible': true
                                                },
                                                'plotArea': {
                                                    'dataLabel': {
                                                        'visible': true
                                                    },
                                                     'colorPalette': [
                '#bb0000',
                '#e9730c',
                '#0a6ed1',
                '#16bd5b',
                'rgb(241, 76, 213)'
            ],
            'drawingEffect': 'glossy'
                                                }
                                            }">

                                                <viz:dataset>
                                                    <viz.data:FlattenedDataset data="{chart>/iflowSeverity}">

                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                        </viz.data:measures>



                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>

                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />

                                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                                </viz:feeds>

                                            </viz:VizFrame>
                                        </f:content>
                                    </f:Card>
                                </f:GridListItem>

                            </f:items>

                        </f:GridList>

                        <viz:Popover id="idPopOver"/>

                        <!-- ===================================================== -->
                        <!-- TOP PROBLEMATIC IFLOWS -->
                        <!-- ===================================================== -->

                        <f:Card semanticRole="ListItem" width="100%">

                            <!-- <f:header>
                                <card:Header title="Top 5 Critical iFlows" level="H1"/>
                            </f:header> -->

                            <f:content>

                                <Table  headerText="Top 5 Critical iFlows" id="idMonitoredArtifacts1" items="{topIflows>/topIflows}" autoPopinMode="true" sticky="ColumnHeaders">

                                    <columns>
                                        <Column width="3rem" hAlign="Center" />

                                        <Column width="40%">
                                            <Text text="iFlow Name" />
                                        </Column>

                                        <Column minScreenWidth="Tablet">
                                            <Text text="Package Name" />
                                        </Column>

                                        <Column minScreenWidth="Tablet">
                                            <Text text="Severity" />
                                        </Column>

                                        <Column minScreenWidth="Tablet" hAlign="Center">
                                            <Text text="Open Clusters" />
                                        </Column>

                                        <Column minScreenWidth="Tablet" hAlign="Center">
                                            <Text text="Open Incidents" />
                                        </Column>

                                        <Column minScreenWidth="Desktop">
                                            <Text text="Last Failure" />
                                        </Column>

                                    </columns>

                                    <items>

                                        <ColumnListItem type="Navigation" press="onTopIflowPress">

                                            <cells>
                                                <core:Icon src="sap-icon://process" size="1.25rem" color="{path: 'topIflows>overallSeverity', formatter: '.formatter.severityIconColor'}"/>
                                                <Title titleStyle="H6" wrapping="true" text="{topIflows>iFlowName}" />
                                                <Text text="{topIflows>PackageName}" />

                                                <Button text="{path: 'topIflows>overallSeverity', formatter: '.formatter.formatButtonText'}" type="{path: 'topIflows>overallSeverity', formatter: '.formatter.formatButtonState'}" icon="{path: 'topIflows>overallSeverity', formatter: '.formatter.formatSeverityIcon'}" class="unclickableTag">
                                                    <customData>
                                                        <core:CustomData key="severity" value="{topIflows>overallSeverity}" />
                                                    </customData>
                                                </Button>

                                                <ObjectNumber number="{topIflows>openClusterCount}" />

                                                <ObjectNumber number="{topIflows>totalIncidents}" emphasized="true" />

                                                <Text text="{path: 'topIflows>lastPollTimestamp', formatter: '.formatter.formatDateTime'}" />

                                            </cells>

                                        </ColumnListItem>

                                    </items>

                                </Table>

                            </f:content>

                        </f:Card>
                    </VBox >
                    <!-- ===================================================== -->
                    <!-- INCIDENT TABLE SECTION -->
                    <!-- ===================================================== -->






                </f:content>

            </f:DynamicPage>

        

</mvc:View>