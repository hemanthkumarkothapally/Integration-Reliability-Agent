<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Overview" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:card="sap.f.cards">

    <f:DynamicPage id="dynamicPage" fitContent="false" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Integration Monitoring Overview" wrapping="true"/>
                </f:heading>
                <f:expandedHeading>
                    <Text text="Manage tenant configuration and data retention policies"></Text>
                </f:expandedHeading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ===================================================== -->
        <!-- PAGE CONTENT -->
        <!-- ===================================================== -->

        <f:content>

            <VBox class="sapUiNoMargin">

                <!-- ===================================================== -->
                <!-- KPI CARDS -->
                <!-- ===================================================== -->

                <f:GridList id="kpiGridList" class="sapUiTinyMarginBottom" width="100%" growing="false">

                    <f:customLayout>
                        <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(16rem, 1fr))" gridGap="1rem" />
                    </f:customLayout>

                    <f:items>

                        <!-- Monitored iFlows -->
                        <f:GridListItem>
                            <HBox width="100%" alignItems="Center" justifyContent="Start" class="sapUiSmallMargin">
                                <VBox class="iconCircle blueIconBg" justifyContent="Center" alignItems="Center">
                                    <core:Icon src="sap-icon://process" size="1.4rem" color="#2563EB"/>
                                </VBox>
                                <VBox class="sapUiSmallMarginBegin">
                                    <Title text="Monitored iFlows" level="H5" class="kpiTitle"/>
                                    <HBox alignItems="Center" justifyContent="Start">
                                        <Text text="{path:'chart>/monitoredIflows', formatter:'.formatter.formatLargeNumber'}" class="kpiValueBlue"/>
                                        <Label text="IFlows" class="sapUiTinyMarginBegin sapUiTinyMarginTop"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </f:GridListItem>

                        <!-- Open Clusters -->
                        <f:GridListItem>
                            <HBox width="100%" alignItems="Center" class="sapUiSmallMargin">
                                <VBox class="iconCircle orangeIconBg" justifyContent="Center" alignItems="Center">
                                    <core:Icon src="sap-icon://chain-link" size="1.4rem" color="#EA580C"/>
                                </VBox>
                                <VBox class="sapUiSmallMarginBegin">
                                    <Title text="Open Clusters" level="H5" class="kpiTitle"/>
                                    <HBox alignItems="Center" justifyContent="Start">
                                        <Text text="{path:'chart>/openClusters', formatter:'.formatter.formatLargeNumber'}" class="kpiValueOrange"/>
                                        <Label text="Error types" class="sapUiTinyMarginBegin sapUiTinyMarginTop"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </f:GridListItem>

                        <!-- Open Incidents -->
                        <f:GridListItem>
                            <HBox width="100%" alignItems="Center" class="sapUiSmallMargin">
                                <VBox class="iconCircle yellowIconBg" justifyContent="Center" alignItems="Center">
                                    <core:Icon src="sap-icon://message-warning" size="1.4rem" color="#D97706"/>
                                </VBox>
                                <VBox class="sapUiSmallMarginBegin">
                                    <Title text="Open Incidents" level="H5" class="kpiTitle"/>
                                    <HBox alignItems="Center" justifyContent="Start">
                                        <Text text="{path:'chart>/openIncidents', formatter:'.formatter.formatLargeNumber'}" class="kpiValueYellow"/>
                                        <Label text="Error logs" class="sapUiTinyMarginBegin sapUiTinyMarginTop"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </f:GridListItem>

                        <!-- Critical iFlows -->
                        <f:GridListItem>
                            <HBox width="100%" alignItems="Center" class="sapUiSmallMargin">
                                <VBox class="iconCircle redIconBg" justifyContent="Center" alignItems="Center">
                                    <core:Icon src="sap-icon://status-critical" size="1.4rem" color="#DC2626"/>
                                </VBox>
                                <VBox class="sapUiSmallMarginBegin">
                                    <Title text="Critical iFlows" level="H5" class="kpiTitle"/>
                                    <HBox alignItems="Center" justifyContent="Start">
                                        <Text text="{path:'chart>/criticalIflows', formatter:'.formatter.formatLargeNumber'}" class="kpiValueRed"/>
                                        <Label text="IFlows" class="sapUiTinyMarginBegin sapUiTinyMarginTop"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </f:GridListItem>

                        <!-- Resolved Clusters -->
                        <f:GridListItem>
                            <HBox width="100%" alignItems="Center" class="sapUiSmallMargin">
                                <VBox class="iconCircle greenIconBg" justifyContent="Center" alignItems="Center">
                                    <core:Icon src="sap-icon://complete" size="1.4rem" color="#16A34A"/>
                                </VBox>
                                <VBox wrap="Wrap" class="sapUiSmallMarginBegin">
                                    <Title text="Resolved Clusters" level="H5" wrapping="true" class="kpiTitle"/>
                                    <HBox alignItems="Center" justifyContent="Start">
                                        <Text text="{path:'chart>/resolvedToday', formatter:'.formatter.formatLargeNumber'}" class="kpiValueGreen"/>
                                        <Label text="Error types" class="sapUiTinyMarginBegin sapUiTinyMarginTop"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </f:GridListItem>

                    </f:items>

                </f:GridList>

                <!-- ===================================================== -->
                <!-- CHARTS -->
                <!-- ===================================================== -->

                <f:GridList class="sapUiTinyMarginBottom" width="100%">

                    <f:customLayout>
                        <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(16rem, 1fr))" gridGap="1rem" />
                    </f:customLayout>

                    <f:items>

                        <!-- Clusters by Severity -->
                        <f:GridListItem type="Active" class="clickableCardItem">
                            <f:Card width="100%" semanticRole="ListItem" height="100%">
                                <f:content>
                                    <viz:VizFrame class="noBorderVizFrame" id="topErrorTypesChart" uiConfig="{applicationSet:'fiori'}" vizType="donut" vizProperties="{
                                                    'title': {
                                                        'visible': true,
                                                        'text': 'Clusters by Severity'
                                                    },
                                                    'legend': {
                                                        'visible': true
                                                    },
                                                    'plotArea': {
                                                        'dataLabel': {
                                                            'visible': true
                                                        },
                                                        'colorPalette': [
                                                                                                        '#e60000',
                                                                                                        '#f28c00',
                                                                                                        '#f4c20d',
                                                                                                        '#00a651'
                                                                                                    ],
                                                        'drawingEffect': 'glossy'
                                                    }
                                                }" width="100%" height="18rem">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chart>/clusterSeverity}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                        </viz:feeds>

                                    </viz:VizFrame>
                                </f:content>
                            </f:Card>
                        </f:GridListItem>

                        <!-- Incidents Over Time -->
                        <f:GridListItem type="Active" class="clickableCardItem">
                            <f:Card width="100%" semanticRole="ListItem" height="100%">
                                <f:content>
                                    <viz:VizFrame class="noBorderVizFrame" id="idLineChart" vizType="column" uiConfig="{applicationSet:'fiori'}" width="100%" height="18rem" vizProperties="{
        'title': {
            'visible': true,
            'text': 'Incidents Over Time'
        },
        'legend': {
            'visible': true,
            'position': 'top',
            'alignment': 'start'
        },
        'plotArea': {
            'dataLabel': {
                'visible': false
            },
            'colorPalette': ['#1565C0', '#E53935'],
            'drawingEffect': 'glossy',
            'window': {
                'start': 'firstDataPoint',
                'end': 'lastDataPoint'
            }
        },
        'valueAxis': {
            'title': { 'visible': false }
        },
        'categoryAxis': {
            'title': { 'visible': false }
        }
    }">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chart>/incidentTrend}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Time" value="{chart>hour}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Total Incidents" value="{chart>totalIncidents}" />
                                                    <viz.data:MeasureDefinition name="Open Incidents" value="{chart>openIncidents}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Total Incidents,Open Incidents"/>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Time"/>
                                        </viz:feeds>

                                    </viz:VizFrame>
                                </f:content>
                            </f:Card>
                        </f:GridListItem>

                        <!-- iFlows by Severity -->
                        <f:GridListItem type="Active" class="clickableCardItem">
                            <f:Card width="100%" semanticRole="ListItem" height="100%">
                                <f:content>
                                    <viz:VizFrame class="noBorderVizFrame" id="severityChart" vizType="donut" width="100%" height="18rem" uiConfig="{applicationSet:'fiori'}" vizProperties="{
                                                'title': {
                                                    'visible': true,
                                                    'text': 'IFlows by Severity'
                                                },
                                                'legend': {
                                                    'visible': true
                                                },
                                                'plotArea': {
                                                    'dataLabel': {
                                                        'visible': true
                                                    },
                                                     'colorPalette': [
                '#bb0000',
                '#e9730c',
                '#481cff',
                '#0a6ed1',
                '#16bd5b'
            ],
            'drawingEffect': 'glossy'
                                                }
                                            }">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chart>/iflowSeverity}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Severity" value="{chart>severity}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Count" value="{chart>count}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Count" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Severity" />
                                        </viz:feeds>

                                    </viz:VizFrame>
                                </f:content>
                            </f:Card>
                        </f:GridListItem>

                    </f:items>

                </f:GridList>

                <viz:Popover id="idPopOver"/>

                <!-- ===================================================== -->
                <!-- TOP PROBLEMATIC IFLOWS -->
                <!-- ===================================================== -->

                <f:Card semanticRole="ListItem" width="100%">

                    <f:content>

                        <Table headerText="Top 5 Critical iFlows" id="idMonitoredArtifacts1" items="{topIflows>/topIflows}" autoPopinMode="true" sticky="ColumnHeaders">

                            <columns>
                                <Column width="3rem" hAlign="Center" />

                                <Column width="40%">
                                    <Text text="iFlow Name" />
                                </Column>

                                <Column width="15%" minScreenWidth="Tablet">
                                    <Text text="Package Name" />
                                </Column>

                                <Column minScreenWidth="Tablet" demandPopin="true">
                                    <Text text="Severity" />
                                </Column>

                                <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                                    <Text text="Active Clusters" />
                                </Column>

                                <Column hAlign="End">
                                    <Text text="Last Failure" />
                                </Column>

                            </columns>

                            <items>

                                <ColumnListItem type="Navigation" press=".onTopIflowPress">

                                    <cells>
                                        <core:Icon src="sap-icon://process" size="1.25rem" color="{path: 'topIflows>overallSeverity', formatter: '.formatter.severityIconColor'}"/>
                                        <Title titleStyle="H6" wrapping="true" text="{topIflows>iFlowName}" />
                                        <Text text="{topIflows>PackageName}" />
                                        <ObjectStatus text="{path:'topIflows>overallSeverity', formatter:'.formatter.formatButtonText'}" icon="{path:'topIflows>overallSeverity', formatter:'.formatter.formatSeverityIcon'}" state="{path:'topIflows>overallSeverity', formatter:'.formatter.formatSeverityState'}">
                                        <customData>
                                            <core:CustomData key="severity" value="{topIflows>overallSeverity}" />
                                        </customData>
                                    </ObjectStatus>

                                        

                                        <ObjectNumber number="{topIflows>openClusterCount}" />

                                        <Text text="{path: 'topIflows>lastErrorAt', formatter: '.formatter.formatDateTime'}" />

                                    </cells>

                                </ColumnListItem>

                            </items>

                        </Table>

                    </f:content>

                </f:Card>

            </VBox>

        </f:content>

    </f:DynamicPage>

</mvc:View>