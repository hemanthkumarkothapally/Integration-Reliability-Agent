<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.OrderList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:card="sap.f.cards">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" 
        preserveHeaderStateOnScroll="true" 
        toggleHeaderOnTitleClick="false">


        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Integration Monitoring Overview"/>
                </f:heading>
                <f:actions>
                    <Button icon="sap-icon://ai" text="Ai Assistant" type="Ghost" press=".onAipress" tooltip="AI Assistant"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <FlexBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="sapUiSmallMarginTop">
                        <items>

                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idIFlowFilter" width="100%" placeholder="Filter by IFlow Name" items="{path:'/MonitoredArtifacts'}" selectionChange=".onFilterChange">
                                        <core:Item key="{iFlowName}" text="{iFlowName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <DateRangeSelection id="idDateRangeFilter" width="100%" placeholder="Select Date Range" change=".onFilterChange" />
                                </items>
                            </VBox>

                            <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>
                                    <Button icon="sap-icon://process" text="{= 'All (' + (${/MonitoredArtifacts/$count} || '0') + ')' }" type="Ghost" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />

                                    <Button icon="sap-icon://error" text="{= 'Critical (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'CRITICAL\''}} || '0') + ')' }" type="Reject" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="CRITICAL" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://warning" text="{= 'High (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'HIGH\''}} || '0') + ')' }" type="Attention" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="HIGH" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://information" text="{= 'Medium (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'MEDIUM\''}} || '0') + ')' }" type="Neutral" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="MEDIUM" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://incident" text="{= 'Low (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'LOW\''}} || '0') + ')' }" type="Accept" press=".onTagPress" class="sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="LOW" />
                                        </customData>
                                    </Button>
                                </items>
                            </FlexBox>

                        </items>
                    </FlexBox>
                </f:content>

            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox width="100%">
                <MessageStrip enableFormattedText="true" text="Click any &lt;strong&gt;iFlow card&lt;/strong&gt; to open the &lt;strong&gt;Detail View&lt;/strong&gt; with all associated clusters and recent incidents." type="Information" showIcon="true" showCloseButton="true" class="sapUiSmallMarginBottom" />


                <f:GridList id="idGridListId" growing="true" growingThreshold="15" class="sapUiNoContentPadding" items="{
                path: '/MonitoredArtifacts',
                sorter: { path: 'modifiedAt', descending: true}
            }">

                    <f:customLayout>
                        <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(17rem, 1fr))" gridGap="1rem" />
                    </f:customLayout>

                    <f:items>
                        <f:GridListItem>
                            <f:Card semanticRole="ListItem" press=".onCardPress">
                                <f:content>
                                    <Panel class="sapUiSmallMargin">
                                        <headerToolbar>
                                            <Toolbar>
                                                <core:Icon src="sap-icon://process" class="sapUiTinyMarginEnd" size="1.5rem" color="{path: 'overallSeverity',formatter: '.formatter.severityIconColor'}"/>

                                                <Title text="{iFlowName}" wrapping="false" titleStyle="H5" />
                                                <ToolbarSpacer  />
                                                <Button text="{ path: 'overallSeverity', formatter: '.formatter.formatButtonText' }" tooltip="click to filter" press=".onTagPress" type="{ path: 'overallSeverity', formatter: '.formatter.formatButtonState' }" icon="{ path: 'overallSeverity', formatter: '.formatter.formatSeverityIcon' }">
                                                    <customData>
                                                        <core:CustomData key="severity" value="{overallSeverity}" />
                                                    </customData>
                                                </Button>
                                                
                                                <!-- <ObjectNumber number="{openClusterCount}" emphasized="true" unit="Clusters" class="sapMObjectNumberLarge sapUiTinyMarginBegin" state="{ path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}"/> -->
                                            </Toolbar>
                                        </headerToolbar>

                                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                                            <!-- <Label text="Severity" /> -->
                                            <Label text="Active Clusters" />
                                            <ObjectNumber number="{openClusterCount}" unit="/{clusters/$count}" emphasized="true" class="sapMObjectNumberLarge sapUiTinyMarginBegin" state="{ path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}"/>

                                            <!-- <ObjectStatus text="{overallSeverity}" state="{ path: 'overallSeverity', formatter: '.formatter.formatSeverityState' }" /> -->
                                        </HBox>

                                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Status" />
                                            <ObjectStatus text="{= ${isActive} === 'Yes' ? 'ACTIVE' : 'INACTIVE' }" state="{= ${isActive} === 'Yes' ? 'Success' : 'Error' }" />
                                        </HBox>

                                        <!-- <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Severity" />
                                            <GenericTag text="{overallSeverity}" design="StatusIconHidden" status="{ path: 'overallSeverity', formatter: '.formatter.formatSeverityState' }" />
                                        </HBox>

                                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Label text="Status" />
                                            <GenericTag text="{= ${isActive} === 'Yes' ? 'ACTIVE' : 'INACTIVE' }" design="StatusIconHidden" status="{= ${isActive} === 'Yes' ? 'Information' : 'Warning' }" />
                                        </HBox> -->


                                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                                            <Label text="Last Poll" />
                                            <Text text="{path: 'lastPollTimestamp', formatter: '.formatter.formatDateTime'}" />
                                        </HBox>
                                    </Panel>
                                </f:content>
                            </f:Card>
                        </f:GridListItem>
                    </f:items>
                </f:GridList>
            </VBox>
        </f:content>

    </f:DynamicPage>
</mvc:View>
