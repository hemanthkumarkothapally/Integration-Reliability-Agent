<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Monitored_iflows"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:card="sap.f.cards">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" preserveHeaderStateOnScroll="true" toggleHeaderOnTitleClick="false">


        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Integration Monitoring Overview"/>
                </f:heading>
                <f:actions>
                    <Button icon="sap-icon://ai" text="Ai Assistant" type="Ghost" press=".onAipress" tooltip="AI Assistant"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <FlexBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="sapUiSmallMarginTop">
                        <items>

                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idIFlowFilter" width="100%" placeholder="Filter by IFlow Name" items="{path:'/MonitoredArtifacts'}" selectionChange=".onFilterChange">
                                        <core:Item key="{iFlowName}" text="{iFlowName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <DateRangeSelection id="idDateRangeFilter" width="100%" placeholder="Select Date Range" change=".onFilterChange" />
                                </items>
                            </VBox>

                            <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>
                                    <Button icon="sap-icon://process" text="{= 'All (' + (${/MonitoredArtifacts/$count} || '0') + ')' }" type="Ghost" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />

                                    <Button icon="sap-icon://error" text="{= 'Critical (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'CRITICAL\''}} || '0') + ')' }" type="Reject" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="CRITICAL" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://warning" text="{= 'High (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'HIGH\''}} || '0') + ')' }" type="Attention" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="HIGH" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://information" text="{= 'Medium (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'MEDIUM\''}} || '0') + ')' }" type="Neutral" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="MEDIUM" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://incident" text="{= 'Low (' + (${path: '/MonitoredArtifacts/$count', parameters: {$filter: 'overallSeverity eq \'LOW\''}} || '0') + ')' }" type="Accept" press=".onTagPress" class="sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="LOW" />
                                        </customData>
                                    </Button>
                                </items>
                            </FlexBox>

                        </items>
                    </FlexBox>
                </f:content>

            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:VerticalLayout width="100%">
                <MessageStrip enableFormattedText="true" text="Click any &lt;strong&gt;iFlow row&lt;/strong&gt; to open the &lt;strong&gt;Detail View&lt;/strong&gt; with all associated clusters and recent incidents." type="Information" showIcon="true" showCloseButton="true" class="sapUiSmallMarginBottom" />

                <Table id="idGridListId" growing="true" growingThreshold="30" growingScrollToLoad="true" mode="SingleSelectMaster" itemPress=".onRowPress" items="{
            path: '/MonitoredArtifacts',
            sorter: { path: 'lastPollTimestamp', descending: true }
        }">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Monitored iFlows" level="H4"/>

                            <ToolbarSpacer />

                            <Text text="Last updated: {globalModel>/lastRefreshTime}" class="sapUiSmallMarginEnd" />

                            <Button icon="sap-icon://refresh" tooltip="Refresh Data" press=".onRefreshPress" type="Transparent" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="3rem" hAlign="Center" />
                        <Column width="40%" demandPopin="true">
                            <Text text="iFlow Name" />
                        </Column>
                        <Column width="20%" hAlign="Begin" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Package" />
                        </Column>
                        <Column width="10%" hAlign="Begin" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Severity" />
                        </Column>
                        <Column width="10%" hAlign="Center" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Active Clusters" />
                        </Column>
                        <Column width="20%" hAlign="End" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Last Poll" />
                        </Column>

                    </columns>

                    <items>
                        <ColumnListItem type="Navigation">
                            <cells>
                                <core:Icon src="sap-icon://process" size="1.25rem" color="{path: 'overallSeverity', formatter: '.formatter.severityIconColor'}"/>

                                <Title text="{iFlowName}" titleStyle="H6" wrapping="true" />
                                <Text text="{PackageName}" />
                                <Button text="{path: 'overallSeverity', formatter: '.formatter.formatButtonText'}" type="{path: 'overallSeverity', formatter: '.formatter.formatButtonState'}" icon="{path: 'overallSeverity', formatter: '.formatter.formatSeverityIcon'}" class="unclickableTag">
                                    <customData>
                                        <core:CustomData key="severity" value="{overallSeverity}" />
                                    </customData>
                                </Button>
                                <ObjectNumber number="{openClusterCount}" emphasized="true" state="{path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}"/>
                                <Text text="{path: 'lastPollTimestamp', formatter: '.formatter.formatDateTime'}" />

                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </layout:VerticalLayout>

        </f:content>

    </f:DynamicPage>
</mvc:View>
