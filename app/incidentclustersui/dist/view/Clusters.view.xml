                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://information" text="{= 'Medium' }" type="Neutral" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="MEDIUM" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://incident" text="{= 'Low' }" type="Accept" press=".onTagPress" class="sapUiTinyMarginBottom sapUiTinyMarginEnd">
                                        <customData>
                                            <core:CustomData key="severity" value="LOW" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://process" text="{= 'All' }" type="Ghost" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="ALL" />
                                        </customData>
                                    </Button>
                                    <Button text="Clear Filters" icon="sap-icon://clear-filter" type="Transparent" press=".onClearFilters" />
                                </items>
                            </FlexBox> -->
                            <ToolbarSpacer ></ToolbarSpacer>
                            <Button text="Clear Filters" icon="sap-icon://clear-filter" type="Transparent" press=".onClearClusterFilters" />

                        </items>
                    </FlexBox>
                </f:content>

            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:VerticalLayout width="100%">

                <Panel width="100%">

                    <!-- Severity Tabs -->
                    <IconTabHeader id="idSeverityTabBar" select=".onSeverityTabSelect" class="sapUiResponsiveContentPadding">

                        <items>
                           <IconTabFilter
    key="ALL"
    text="All"
    icon="sap-icon://list"
    iconColor="Neutral"/>

<IconTabFilter
    key="CRITICAL"
    text="Critical"
    icon="sap-icon://error"
    iconColor="Negative"/>

<IconTabFilter
    key="HIGH"
    text="High"
    icon="sap-icon://alert"
    iconColor="Critical"/>

<IconTabFilter
    key="MEDIUM"
    text="Medium"
    icon="sap-icon://information"
    iconColor="Default"/>

<IconTabFilter
    key="LOW"
    text="Low"
    icon="sap-icon://sys-help-2"
    iconColor="Positive"/></items>

                    </IconTabHeader>

                    <!-- Clusters Table -->
                    <Table id="idClusters" updateFinished=".onTableUpdateFinished" growing="true" sticky="HeaderToolbar,ColumnHeaders" growingThreshold="30" growingScrollToLoad="true" mode="SingleSelectMaster" itemPress=".onRowPress" items="{
                    path: '/IncidentClusters',
                    parameters: {
                        $count: true,
                        $expand: {
                            'monitoredArtifacts': {
                                '$count': true
                            }
                        }
                    },
                    sorter: {
                        path: 'lastSeen',
                        descending: true
                    }
                }">

                        <!-- <headerToolbar>
                    <OverflowToolbar>
                        <Title id="idTableTitleC" text="{= 'Clusters (' + ${/IncidentClusters/$count} + ')' }" level="H4"/>

                        <ToolbarSpacer/>

                        <Button icon="sap-icon://refresh" tooltip="Refresh Data" press=".onRefreshPress" type="Transparent"/>
                    </OverflowToolbar>
                </headerToolbar> -->

                        <columns>
                            <Column width="3rem" hAlign="Center"/>
                            <Column width="30%" demandPopin="true">
                                <Text text="Error Type"/>
                            </Column>
                            <Column  hAlign="Center" demandPopin="true" minScreenWidth="Tablet">
                                <Text text="Artifacts"/>
                            </Column>
                            <Column  hAlign="Begin" demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Severity"/>
                            </Column>
                            <Column  hAlign="Center" demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Incident Count"/>
                            </Column>
                            <Column  hAlign="Begin" demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Status"/>
                            </Column>
                            <Column  hAlign="End">
                                <Text text="Last Failure"/>
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem >
                                <cells>

                                    <core:Icon src="sap-icon://chain-link" size="1.25rem" color="{path:'severity', formatter:'.formatter.severityIconColor'}"/>

                                    <Title text="{errorType}" titleStyle="H6" wrapping="true"/>

                                    <ObjectNumber number="{monitoredArtifacts/$count}"/>

                                    <Button text="{path:'severity', formatter:'.formatter.formatButtonText'}" type="{path:'severity', formatter:'.formatter.formatButtonState'}" icon="{path:'severity', formatter:'.formatter.formatSeverityIcon'}" class="unclickableTag">

                                        <customData>
                                            <core:CustomData key="severity" value="{severity}"/>
                                        </customData>

                                    </Button>

                                    <Text text="{incidentCount}"/>

                                    <ObjectStatus text="{path:'globalStatus', formatter:'.formatter.formatStatusText'}" state="{path:'globalStatus', formatter:'.formatter.formatStatusState'}"/>

                                    <Text text="{path:'lastSeen', formatter:'.formatter.formatDateTime'}"/>

                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>

                </Panel>

            </layout:VerticalLayout>
        </f:content>

    </f:DynamicPage>
</mvc:View>