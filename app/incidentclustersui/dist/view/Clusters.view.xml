                                </layoutData>
                                <items>
                                    <MultiComboBox id="idTenantFilterC" width="100%" placeholder="Filter by Tenant" items="{path:'/Tenants'}" selectionChange=".onFilterChange">
                                        <core:Item key="{ID}" text="{tenantName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox> -->


                            <!-- <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>

                                    <Button icon="sap-icon://error" text="{= 'Critical' }" type="Reject" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
