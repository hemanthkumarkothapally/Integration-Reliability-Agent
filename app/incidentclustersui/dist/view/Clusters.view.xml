<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Clusters" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <f:DynamicPage id="dynamicPageIdC" headerExpanded="true" preserveHeaderStateOnScroll="true" toggleHeaderOnTitleClick="false">


        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <items>
                            <!-- <Button icon="sap-icon://nav-back" type="Ghost" press=".onNavBackToOverview" class="sapUiSmallMarginEnd"/> -->
                            <Title text="Clusters" wrapping="true" />
                        </items>
                    </HBox>
                </f:heading>

                <!-- <f:expandedContent>
                    <Label text="Monitor your iFlows &amp; Associated Clusters" class="sapUiSmallMarginBegin" />
                </f:expandedContent> -->

                <f:actions>
                    <Button icon="sap-icon://ai" text="Ai Assistant" type="Ghost" press=".onAipress" tooltip="AI Assistant"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <FlexBox alignItems="Start" justifyContent="SpaceBetween" wrap="Wrap" width="100%" class="sapUiSmallMarginTop">
                        <items>

                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox showClearIcon="true" id="idClustersCombo" width="100%" placeholder="Filter by Error Type" items="{path:'/IncidentClusters'}" selectionChange=".onclusterFilterChange">
                                        <core:Item key="{errorType}" text="{errorType}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <DateRangeSelection id="idDateRangeFilterC" width="100%" placeholder="Select Date Range" change=".onFilterChange" />
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idpackageFilterC" width="100%" placeholder="Filter by Package Name" items="{
                                        path: '/MonitoredArtifacts',
                                        parameters: {
                                            $apply: 'groupby((PackageName))'
                                        }
                                    }" selectionChange=".onFilterChange">
                                        <core:Item key="{PackageName}" text="{PackageName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>
                            <VBox width="auto" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idTenantFilterC" width="100%" placeholder="Filter by Tenant" items="{path:'/Tenants'}" selectionChange=".onFilterChange">
                                        <core:Item key="{ID}" text="{tenantName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>


                            <FlexBox wrap="Wrap" justifyContent="Start" class="sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>

                                    <Button icon="sap-icon://error" text="{= 'Critical' }" type="Reject" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="CRITICAL" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://warning" text="{= 'High' }" type="Attention" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="HIGH" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://information" text="{= 'Medium' }" type="Neutral" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="MEDIUM" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://incident" text="{= 'Low' }" type="Accept" press=".onTagPress" class="sapUiTinyMarginBottom sapUiTinyMarginEnd">
                                        <customData>
                                            <core:CustomData key="severity" value="LOW" />
                                        </customData>
                                    </Button>

                                    <Button icon="sap-icon://process" text="{= 'All' }" type="Ghost" press=".onTagPress" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                        <customData>
                                            <core:CustomData key="severity" value="ALL" />
                                        </customData>
                                    </Button>
                                    <Button text="Clear Filters" icon="sap-icon://clear-filter" type="Transparent" press=".onClearFilters" />
                                </items>
                            </FlexBox>

                        </items>
                    </FlexBox>
                </f:content>

            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:VerticalLayout width="100%">
                <!-- <MessageStrip enableFormattedText="true" text="Click any &lt;strong&gt;iFlow row&lt;/strong&gt; to open the &lt;strong&gt;Detail View&lt;/strong&gt; with all associated clusters and recent incidents." type="Information" showIcon="true" showCloseButton="true" class="sapUiSmallMarginBottom" /> -->

                <Table id="idClusters" updateFinished=".onTableUpdateFinished" growing="true" growingThreshold="30" growingScrollToLoad="true" mode="SingleSelectMaster" itemPress=".onRowPress" items="{
    path: '/IncidentClusters',
    parameters: {
        $count: true,
        $expand: {
            'monitoredArtifacts': {
                '$count': true
            }
        }
    },
    sorter: {
        path: 'lastSeen',
        descending: true
    }
}">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title id = "idTableTitleC" text="{= 'Clusters (' + ${/IncidentClusters/$count} + ')' }" level="H4"/>

                            <ToolbarSpacer />

                            <!-- <Text text="Last updated: {globalModel>/lastRefreshTime}" class="sapUiSmallMarginEnd" /> -->

                            <Button icon="sap-icon://refresh" tooltip="Refresh Data" press=".onRefreshPress" type="Transparent" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="3rem" hAlign="Center" />
                        <Column width="30%" demandPopin="true">
                            <Text text="Error Type" />
                        </Column>
                        <Column width="10%" hAlign="Center" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Artifacts" />
                        </Column>
                        <Column width="20%" hAlign="Begin" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Severity" />
                        </Column>
                        <Column width="10%" hAlign="Center" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Incident Count" />
                        </Column>
                        <Column width="10%" hAlign="Center" demandPopin="true" minScreenWidth="Tablet">
                            <Text text="Status" />
                        </Column>
                        <Column width="20%" hAlign="End" demandPopin="true" minScreenWidth="Desktop">
                            <Text text="Last Failure" />
                        </Column>

                    </columns>

                    <items>
                        <ColumnListItem >
                            <cells>
                                <core:Icon src="sap-icon://share-2" size="1.25rem" color="{path: 'severity', formatter: '.formatter.severityIconColor'}"/>

                                <Title text="{errorType}" titleStyle="H6" wrapping="true" />
                                <!-- Associated Monitored Artifacts Count -->
                           <ObjectNumber number="{monitoredArtifacts/$count}" />
                                <Button text="{path: 'severity', formatter: '.formatter.formatButtonText'}" type="{path: 'severity', formatter: '.formatter.formatButtonState'}" icon="{path: 'severity', formatter: '.formatter.formatSeverityIcon'}" class="unclickableTag">
                                    <customData>
                                        <core:CustomData key="severity" value="{severity}" />
                                    </customData>
                                </Button>
                                <Text text="{incidentCount}" />
                                <ObjectStatus text="{path: 'globalStatus', formatter: '.formatter.formatStatusText'}" state="{path: 'globalStatus', formatter: '.formatter.formatStatusState'}" />

                                <!-- <ObjectNumber number="{openClusterCount}" emphasized="true" state="{path: 'overallSeverity', formatter: '.formatter.formatSeverityState'}"/> -->
                                <Text text="{path: 'lastSeen', formatter: '.formatter.formatDateTime'}" />

                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </layout:VerticalLayout>

        </f:content>

    </f:DynamicPage>
</mvc:View>