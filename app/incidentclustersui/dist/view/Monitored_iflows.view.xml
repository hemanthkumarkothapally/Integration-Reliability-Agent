<mvc:View controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Monitored_iflows"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" preserveHeaderStateOnScroll="true" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <items>
                            <Title text="Monitoring IFlows" wrapping="true" />
                        </items>
                    </HBox>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <FlexBox alignItems="Start" justifyContent="Start" wrap="Wrap" width="100%" class="sapUiSmallMarginTop">
                        <items>

                            <VBox width="250px" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idIFlowFilter" width="100%" placeholder="Filter by IFlow Name" items="{path:'/MonitoredArtifacts'}" selectionChange=".onFilterChange">
                                        <core:Item key="{iFlowName}" text="{iFlowName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>

                            <VBox width="250px" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>
                                    <DateRangeSelection id="idDateRangeFilter" width="100%" placeholder="Select Date Range" change=".onFilterChange" />
                                </items>
                            </VBox>

                            <VBox width="250px" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <layoutData>
                                    <FlexItemData growFactor="0" />
                                </layoutData>
                                <items>
                                    <MultiComboBox id="idpackageFilter" width="100%" placeholder="Filter by Package Name" items="{
        path:'/MonitoredArtifacts',
        parameters:{
            $apply:'groupby((PackageName,tenant_ID))'
        }
    }" selectionChange=".onFilterChange">
                                        <core:Item key="{PackageName}" text="{PackageName}" />
                                    </MultiComboBox>
                                </items>
                            </VBox>

                            <Button text="Clear Filters" icon="sap-icon://clear-filter" type="Transparent" press=".onClearFilters" />

                        </items>
                    </FlexBox>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <layout:VerticalLayout width="100%">

                <MessageStrip enableFormattedText="true" text="Click any &lt;strong&gt;iFlow row&lt;/strong&gt; to open the &lt;strong&gt;Detail View&lt;/strong&gt; with all associated clusters and recent incidents." type="Information" showIcon="true" showCloseButton="true" class="sapUiSmallMarginBottom" />

                <Panel width="100%">

                    <!-- Severity Tabs -->
                    <IconTabHeader id="idIFLowSeverityTabBar" select=".onSeverityTabSelect" class="sapUiResponsiveContentPadding">
                        <items>
                            <IconTabFilter id="allTab" key="ALL" text="All" icon="sap-icon://list" iconColor="Neutral" />
                            <IconTabFilter id="criticalTab" key="CRITICAL" text="Critical" icon="sap-icon://error" iconColor="Negative" />
                            <IconTabFilter id="highTab" key="HIGH" text="High" icon="sap-icon://alert" iconColor="Critical" />
                            <IconTabFilter id="mediumTab" key="MEDIUM" text="Medium" icon="sap-icon://information" />
                            <IconTabFilter id="lowTab" key="LOW" text="Low" icon="sap-icon://sys-help-2" iconColor="Default" />
                            <IconTabFilter id="healthyTab" key="HEALTHY" text="Healthy" icon="sap-icon://sys-enter-2" iconColor="Positive" />
                        </items>
                    </IconTabHeader>
                    <!-- Monitored Artifacts Table -->
                    <Table id="idMonitoredArtifacts" updateFinished=".onTableUpdateFinished" growing="true" sticky="HeaderToolbar,ColumnHeaders" growingThreshold="20" growingScrollToLoad="true" mode="SingleSelectMaster" itemPress=".onRowPress" items="{
                    path: '/MonitoredArtifacts',
                    parameters: {
                        $count: true
                    },
                    sorter: {
                        path: 'lastErrorAt',
                        descending: true
                    }
                }">

                        <headerToolbar>
                            <OverflowToolbar>
                                <ToolbarSpacer/>
                                <Text text="Last updated: {globalModel>/lastRefreshTime}" class="sapUiSmallMarginEnd"/>
                                <Button icon="sap-icon://refresh" tooltip="Refresh Data" press=".onRefreshPress" type="Transparent"/>
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>

                            <Column width="3rem" hAlign="Center"/>

                            <Column width="40%" demandPopin="true">
                                <Text text="iFlow Name"/>
                            </Column>

                            <Column width="20%" demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Package"/>
                            </Column>

                            <Column demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Severity"/>
                            </Column>

                            <Column hAlign="Center" demandPopin="true" minScreenWidth="Desktop">
                                <Text text="Active Clusters"/>
                            </Column>

                            <Column hAlign="End">
                                <Text text="Last Failure"/>
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem type="Navigation">

                                <cells>

                                    <core:Icon src="sap-icon://process" size="1.25rem" color="{path:'overallSeverity', formatter:'.formatter.severityIconColor'}"/>

                                    <Title text="{iFlowName}" titleStyle="H6" wrapping="true"/>

                                    <Text text="{PackageName}"/>

                                    <ObjectStatus text="{path:'overallSeverity', formatter:'.formatter.formatButtonText'}" icon="{path:'overallSeverity', formatter:'.formatter.formatSeverityIcon'}" state="{path:'overallSeverity', formatter:'.formatter.formatSeverityState'}">
                                        <customData>
                                            <core:CustomData key="severity" value="{overallSeverity}" />
                                        </customData>
                                    </ObjectStatus>

                                    <ObjectNumber number="{openClusterCount}" emphasized="true" state="{path:'overallSeverity', formatter:'.formatter.formatSeverityState'}"/>

                                    <Text text="{path:'lastErrorAt', formatter:'.formatter.formatDateTime'}"/>

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </Panel>

            </layout:VerticalLayout>
        </f:content>

    </f:DynamicPage>
</mvc:View>