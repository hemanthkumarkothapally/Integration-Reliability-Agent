<mvc:View xmlns:cssgrid="sap.ui.layout.cssgrid" xmlns:form="sap.ui.layout.form"
    controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Settings"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:cards="sap.f.cards"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <f:DynamicPage showFooter="true">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Settings" wrapping="true"/>
                </f:heading>
                <f:expandedHeading>
                    <Text text="Manage tenant configuration and data retention policies"/>
                </f:expandedHeading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
        

                            <!-- ============================================ -->
                            <!-- 1. TENANT CONFIGURATION                      -->
                            <!-- ============================================ -->
                            <f:GridList >
                            <f:customLayout>
                                <cssgrid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(30rem, 2fr))" gridGap="1rem" />
                            </f:customLayout>
                            <f:items>
                            <f:GridListItem >
                            <f:Card height="100%" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://building"
                                        title="1. Tenant Configuration"
                                        subtitle="Default Dashboard Tenant"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                        <Label text="Default Dashboard Tenant"/>
                                        <Select
                                            width="100%"
                                            selectedKey="{settingsModel>/DEFAULT_TENANT/settingValue}"
                                            items="{globalModel>/tenants}"
                                            enabled="{= !${globalModel>/editMode}}"
                                            change=".onTenantChange">
                                            <core:Item
                                                key="{globalModel>ID}"
                                                text="{globalModel>tenantName}"/>
                                        </Select>
                                        <MessageStrip
                                            class="sapUiMediumMarginTop"
                                            type="Information"
                                            showIcon="true"
                                            text="This tenant will be selected automatically when users open the dashboard."/>
                                            <VBox
                                        visible="{globalModel>/editMode}"
                                        class="sapUiMediumMarginTop">

                                        <Toolbar>
                                            <Title text="Tenant Management" level="H5"/>
                                            <ToolbarSpacer/>
                                            <Button
                                                text="Add Tenant"
                                                icon="sap-icon://add"
                                                type="Emphasized"
                                                press=".onAddTenant"/>
                                        </Toolbar>

                                        <Table
                                        id="tenantTable"
                                            items="{path: '/Tenants'}"
                                            class="sapUiSmallMarginTop" autoPopinMode="true">
                                            <columns>
                                                <Column demandPopin="true">
                                                    <Text text="Tenant Name"/>
                                                </Column>
                                                <Column>
                                                    <Text text="Tenant ID"/>
                                                </Column>
                                                <Column>
                                                    <Text text="Destination"/>
                                                </Column>
                                                <Column>
                                                    <Text text="URL"/>
                                                </Column>
                                                <Column visible="false" >
                                                <Text text="IsActive"></Text>
                                                </Column>
                                                <Column hAlign="Center">
                                                    <Text text="Actions"/>
                                                </Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem>
                                                    <cells>
                                                        <Text text="{tenantName}"/>
                                                        <Text text="{tenantId}"/>
                                                        <Text text="{destinationName}"/>
                                                        <Text text="{url}"/>
                                                        <Text text="{isActive}" visible="false"></Text>
                                                        <HBox justifyContent="Center">
                                                            <Button
                                                                icon="sap-icon://edit"
                                                                type="Transparent"
                                                                press=".onEditTenant"/>
                                                            <Button
                                                                icon="sap-icon://delete"
                                                                type="Transparent"
                                                                press=".onDeleteTenant"/>
                                                        </HBox>
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </VBox>
                                                </VBox>
                                </f:content>
                            </f:Card>
</f:GridListItem>
<f:GridListItem>

                            <!-- ============================================ -->
                            <!-- 2. AI CONFIGURATION                          -->
                            <!-- ============================================ -->
                            <f:Card height="100%" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://artificial-intelligence"
                                        title="2. AI Configuration"
                                        subtitle="Recommendation Engine Settings"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                    <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                                <Label text="AI Provider"/>
                                                <Text text="{globalModel>/settings/AI_PROVIDER}" />
                                                <Label text="Model"/>
                                                <Text text="{globalModel>/settings/AI_MODEL}"></Text>
                                                <Label text="Max Incidents Sent to AI"/>
                                                <StepInput
                                                    width="100%"
                                                    description="Count"
                                                    textAlign="Center"
                                                    min="1"
                                                    max="100"
                                                    value="{globalModel>/settings/MAX_INCIDENTS_FOR_AI}"
                                                    enabled="{globalModel>/editMode}"/>
                                                <Label text="Historical Messages Count"/>
                                                <StepInput
                                                    width="100%"
                                                    description="Count"
                                                    textAlign="Center"
                                                    min="0"
                                                    max="100"
                                                    value="{globalModel>/settings/HISTORY_MESSAGE_COUNT}"
                                                    enabled="{globalModel>/editMode}"/>
                                                <Label text="Auto Generate Recommendations"/>
                                                <Label text="Automatically generate recommendations after clustering."/>
                                                <Switch
                                                   
                                                    enabled="{globalModel>/editMode}"/> 
                                    </form:content>
                                    </form:SimpleForm>
                                    </VBox>
                                </f:content>
                            </f:Card>
</f:GridListItem>
<f:GridListItem>

                            <!-- ============================================ -->
                            <!-- 3. POLLING CONFIGURATION                     -->
                            <!-- ============================================ -->
                            <f:Card height="100%" class="sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://refresh"
                                        title="3. Polling Configuration"
                                        subtitle="Monitoring Schedule"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                         <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                    <Label text="Polling Mode"></Label>
                                     <RadioButtonGroup
                                                columns="2"
                                                enabled="{globalModel>/editMode}"
                                                selectedIndex="{
                                                    path: 'settingsModel>/POLLING_MODE/settingValue',
                                                    formatter: '.formatPollingModeIndex'
                                                }"
                                                select=".onPollingModeChange">
                                                <RadioButton text="Automatic"/>
                                                <RadioButton text="Manual"/>
                                            </RadioButtonGroup>
                                             <Label text="Polling Frequency"/>
                                             <StepInput
                                                    width="100%"
                                                    description="Mins"
                                                    textAlign="Center"
                                                    min="5"
                                                    max="180"
                                                    step="5"
                                                    value="{settingsModel>/POLLING_INTERVAL_MINUTES/settingValue}"
                                                    enabled="{globalModel>/editMode}"/>
                                    </form:content>
                                    </form:SimpleForm>

                                        <!-- Poll Now -->
                                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiMediumMarginTop">
                                            <Button
                                                text="Poll Now"
                                                icon="sap-icon://play"
                                                press=".onPollNow"/>
                                            <Text text="Last Poll: {globalModel>/lastPoll}"/>
                                        </HBox>
                                    </VBox>
                                </f:content>
                            </f:Card>
</f:GridListItem>
<f:GridListItem>

                            <!-- ============================================ -->
                            <!-- 4. CHAT & HISTORY CONFIGURATION              -->
                            <!-- ============================================ -->
