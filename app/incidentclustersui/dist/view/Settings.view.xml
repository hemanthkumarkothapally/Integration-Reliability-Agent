                            <!-- ============================================ -->
                            <!-- 6. DATA RETENTION                            -->
                            <!-- ============================================ -->
                            <f:Card height="100%" class="sapUiMediumMarginBottom">
                                <f:header>
                                    <cards:Header
                                        iconSrc="sap-icon://database"
                                        title="4. Data Retention"
                                        subtitle="Automatic Cleanup Configuration"/>
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiMediumMargin">
                                <form:SimpleForm layout="ColumnLayout" editable="true">
                                    <form:content>
                                            <Label text="Incident Retention Days"/>
                                            <StepInput
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{settingsModel>/INCIDENT_RETENTION_DAYS/settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                            <Label text="Cluster Retention Days"/>
                                            <StepInput
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{settingsModel>/CLUSTER_RETENTION_DAYS/settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                            <Label text="Monitoring Iflows Retention Days"/>
                                            <StepInput
                                               width="100%"
                                                description="Count"
                                                textAlign="Center"
                                                min="1"
                                                max="3650"
                                                value="{settingsModel>/MONITORING_RETENTION_DAYS/settingValue}"
                                                enabled="{globalModel>/editMode}"/>
                                                </form:content>
                                    </form:SimpleForm>

                                        <MessageStrip
                                            class="sapUiMediumMarginTop"
                                            type="Warning"
                                            showIcon="true"
                                            text="Records older than the configured retention period will be automatically deleted by scheduled cleanup jobs."/>
                                    </VBox>
                                  
                                </f:content>
                            </f:Card>
</f:GridListItem>
                            </f:items>
                            </f:GridList>
                      
                    

        </f:content>

        <!-- ====================================================== -->
        <!-- FOOTER: Edit / Cancel / Save + Reset                   -->
        <!-- ====================================================== -->
        <f:footer>
            <Toolbar>
                <Button
                    text="Reset to Defaults"
                    icon="sap-icon://reset"
                    type="Transparent"
                    visible="{globalModel>/editMode}"
                    press=".onResetDefaults"/>

                <ToolbarSpacer/>

                <Button
                    text="Edit"
                    icon="sap-icon://edit"
                    type="Emphasized"
                    visible="{= !${globalModel>/editMode} }"
                    press=".onEdit"/>

                <Button
                    text="Cancel"
                    icon="sap-icon://decline"
                    visible="{globalModel>/editMode}"
                    press=".onCancel"/>

                <Button
                    text="Save Settings"
                    icon="sap-icon://save"
                    type="Accept"
                    visible="{globalModel>/editMode}"
                    press=".onSave"/>
            </Toolbar>
        </f:footer>

    </f:DynamicPage>

</mvc:View>