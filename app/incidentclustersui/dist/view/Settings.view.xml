<mvc:View xmlns:layout="sap.ui.layout" xmlns:cards="sap.f.cards"
    controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.Settings"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
<f:DynamicPage showFooter="true">
<f:title>
            <f:DynamicPageTitle>
                <f:heading>                         
                   <Title text="Settings" wrapping="true" />        
                </f:heading>
                <f:expandedHeading>
                <Text text="Manage tenant configuration and data retention policies"></Text>
                </f:expandedHeading>
            </f:DynamicPageTitle>
        </f:title>
        
<f:content>
        <VBox width="100%">
        <layout:Grid 
    defaultSpan="XL6 L6 M12 S12"
    hSpacing="1"
    vSpacing="1">
                
                <!-- Tenant Configuration -->
                <f:Card
                    class="sapUiMediumMarginEnd sapUiMediumMarginBottom" height="100%">
                    <f:layoutData>
                    
            <FlexItemData
                growFactor="1"
                baseSize="250px" />
        </f:layoutData>
       
                   <f:header>
        <cards:Header
            title="Tenant Configuration"
            subtitle="Default Dashboard Tenant">
        </cards:Header>
    </f:header>
                    <f:content>
                        <VBox class="sapUiMediumMargin" width="100%">
                            <Label
                                text="Default Tenant"
                                required="true" visible="{= !${globalModel>/editMode} }"/>
<Select
    width="100%"
    selectedKey="{globalModel>/settings/DEFAULT_TENANT}"
    items="{globalModel>/tenants}"
    change=".onTenantChange" visible="{= !${globalModel>/editMode} }">

    <core:Item
        key="{globalModel>ID}"
        text="{globalModel>tenantName}" />

</Select>

                            <MessageStrip
                                class="sapUiMediumMarginTop"
                                type="Information"
                                showIcon="true"
                                visible="{= !${globalModel>/editMode} }"
                                text="This tenant will be selected automatically when users open the dashboard." />
<VBox
    visible="{globalModel>/editMode}"
    class="sapUiMediumMarginTop">

    <Toolbar>
        <Title text="Tenant Management" level="H5"/>
        <ToolbarSpacer/>
        <Button
            text="Add Tenant"
            icon="sap-icon://add"
            type="Emphasized"
            press=".onAddTenant"/>
    </Toolbar>

    <Table
        items="{path: '/Tenants'}"
        class="sapUiSmallMarginTop">

        <columns>

            <Column>
                <Text text="Tenant Name"/>
            </Column>

            <Column>
                <Text text="Tenant ID"/>
            </Column>

            <Column>
                <Text text="Destination"/>
            </Column>

            <Column>
                <Text text="Region"/>
            </Column>

            <Column hAlign="Center">
                <Text text="Actions"/>
            </Column>

        </columns>

        <items>

            <ColumnListItem>

                <cells>

                    <Text text="{tenantName}"/>

                    <Text text="{tenantId}"/>

                    <Text text="{destinationName}"/>

                    <Text text="{region}"/>

                    <HBox justifyContent="Center">

                        <Button
                            icon="sap-icon://edit"
                            type="Transparent"
                            press=".onEditTenant"/>

                        <Button
                            icon="sap-icon://delete"
                            type="Transparent"
                            press=".onDeleteTenant"/>

                    </HBox>

                </cells>

            </ColumnListItem>

        </items>

    </Table>

</VBox>
                        </VBox>

                    </f:content>

                </f:Card>

                <!-- Retention -->

                <f:Card height="100%">
<f:layoutData>
                    
            <FlexItemData
                growFactor="2"
                baseSize="500px" />
        </f:layoutData>
                    <f:header>

                        <cards:Header
                            title="Data Retention"
                            subtitle="Automatic Cleanup Configuration" />
                    </f:header>

                    <f:content>

                        <VBox class="sapUiMediumMargin">

                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center">

                                <VBox width="70%">

                                    <Label
                                        text="Incident Retention Days" />

                                    <Text
                                        text="Number of days incident records should remain in the database." />

                                </VBox>

                                <StepInput enabled="{globalModel>/editMode}" step="1" textAlign="Center" value="{globalModel>/settings/INCIDENT_RETENTION_DAYS}" />

                            </HBox>

                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                class="sapUiMediumMarginTop">

                                <VBox width="70%">

                                    <Label text="Cluster Retention Days" />
                                    <Text
                                        text="Number of days cluster records should remain in the database." />

                                </VBox>

                                <StepInput enabled="{globalModel>/editMode}" step="1" textAlign="Center" value="{globalModel>/settings/CLUSTER_RETENTION_DAYS}" />

                            </HBox>

                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                class="sapUiMediumMarginTop">

                                <VBox width="70%">

                                    <Label
                                        text="Monitoring Retention Days" />

                                    <Text
                                        text="Number of days monitoring and trend data should remain in the database." />

                                </VBox>

                                <StepInput enabled="{globalModel>/editMode}" step="1" textAlign="Center" value="{globalModel>/settings/MONITORING_RETENTION_DAYS}" />

                            </HBox>

                            <MessageStrip
                                class="sapUiMediumMarginTop"
                                type="Warning"
                                showIcon="true"
                                text="Records older than the configured retention period will be automatically deleted by scheduled cleanup jobs." />

                        </VBox>

                    </f:content>

                </f:Card>

           </layout:Grid>
        </VBox>
    
    </f:content>
    <f:footer>
  <Toolbar>

    <ToolbarSpacer />

    <Button
        text="Edit"
        icon="sap-icon://edit"
        type="Emphasized"
        visible="{= !${globalModel>/editMode} }"
        press=".onEdit" />

    <Button
        text="Cancel"
        icon="sap-icon://decline"
        visible="{globalModel>/editMode}"
        press=".onCancel" />

    <Button
        text="Save"
        icon="sap-icon://save"
        type="Accept"
        visible="{globalModel>/editMode}"
        press=".onSave" />

</Toolbar>
    </f:footer>
</f:DynamicPage>

</mvc:View>