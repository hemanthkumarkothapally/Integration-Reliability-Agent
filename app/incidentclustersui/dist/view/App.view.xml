<mvc:View xmlns:core="sap.ui.core" controllerName="com.cytechies.integration.reliability.incidentclustersui.controller.App" displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m">
    <tnt:ToolPage id="toolPage1" sideExpanded="false" >

        <tnt:header>
            <tnt:ToolHeader>
                <!-- <Button icon="sap-icon://menu2" press=".onSideNavButtonPress"/> -->
                

                <Title text="Integration Reliability Agent"/>
                <ToolbarSpacer ></ToolbarSpacer>
<Title
    level="H5"
    text="Tenant: {=${globalModel>/selectedTenantName} || 'ALL'}"/>            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation selectedKey="{globalModel>/selectedKey}" id="sideNavigation" >
                
                <!-- Main scrollable navigation items -->
                <tnt:NavigationList itemSelect=".onSideNavigationSelect">
                    <tnt:NavigationListItem  key="overview" text="Overview" icon="sap-icon://home"/>
                    <tnt:NavigationListItem key="iflows" text="iFlows" icon="sap-icon://process"/>
                    <tnt:NavigationListItem key="clusters" text="Clusters" icon="sap-icon://chain-link"/>
                    <tnt:NavigationListItem key="ai" text="AI Assistant" icon="sap-icon://ai"/>
                    <!-- <tnt:NavigationListItem key="incidents" text="Incidents" icon="sap-icon://alert"/> -->
                </tnt:NavigationList>

                <!-- CORRECTED: Fixed bottom item aggregation inside SideNavigation -->
                <tnt:fixedItem>
                    <tnt:NavigationList itemSelect=".onSideNavigationSelect">
                        <tnt:NavigationListItem key="Settings" text="Settings" icon="sap-icon://action-settings" />
                    </tnt:NavigationList>
                </tnt:fixedItem>

            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="app"/>
        </tnt:mainContents>

    </tnt:ToolPage>
</mvc:View>